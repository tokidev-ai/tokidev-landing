---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Senior Fullstack Engineer — building scalable products with clean code.' } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Favicon e Identidad Visual (Referenciado al isotipo oficial) -->
    <link rel="icon" type="image/svg+xml" href="/assets/logos/IsotivoTokidev.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Meta descripción optimizada para motores de búsqueda (SEO) -->
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Carga optimizada de la tipografía principal Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Slot para meta tags de OpenGraph o recursos adicionales por página -->
    <slot name="head" />
  </head>
  <body class="bg-brand-bg text-brand-text antialiased selection:bg-brand-orange/30">
    <!-- Wrapper: posiciona los glows relativos al contenido real, evitando scroll extra -->
    <div class="relative overflow-hidden">
      <slot name="background" />
      <slot />
    </div>
  </body>
</html>

<script>
  import { initAnimations } from '../scripts/animations';
  initAnimations();
</script>
