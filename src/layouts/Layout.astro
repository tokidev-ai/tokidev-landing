---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Senior Fullstack Engineer — building scalable products with clean code.' } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Slot para meta tags o estilos adicionales por página -->
    <slot name="head" />
  </head>
  <body class="bg-brand-bg text-brand-text antialiased selection:bg-brand-orange/30 overflow-x-hidden">
    <slot />
  </body>
</html>
