---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import CTANewsletter from '../../components/CTANewsletter.astro';
import BlogCard from '../../components/BlogCard.astro';
import BackgroundGlowsArticle from '../../components/BackgroundGlowsArticle.astro';

export async function getStaticPaths() {
  const posts = import.meta.glob('../../posts/*.md', { eager: true });

  return Object.entries(posts).map(([path, post]: [string, any]) => {
    const slug = path.split('/').pop()?.replace('.md', '');
    return { params: { slug }, props: { post } };
  });
}

const { post } = Astro.props;
const { title, excerpt, category, date, readTime, color } = post.frontmatter;
const Content = post.default;

// Posts relacionados: todos excepto el actual (máx. 3)
const allPosts = import.meta.glob('../../posts/*.md', { eager: true });
const relatedPosts = Object.entries(allPosts)
  .filter(([, p]: [string, any]) => p.frontmatter.title !== title)
  .slice(0, 3)
  .map(([path, p]: [string, any]) => ({
    ...p.frontmatter,
    url: `/blog/${path.split('/').pop()?.replace('.md', '')}`,
  }));
---

<Layout title={`${title} - Tokidev Blog`} description={excerpt}>
  <!-- Wrapper principal con contexto de posicionamiento para los glows -->
  <div class="relative w-full max-w-[1440px] mx-auto min-h-screen pt-28">
    <BackgroundGlowsArticle />
    <Navbar />

    <main class="w-full flex flex-col items-center pb-24">
      <div class="w-[92%] max-w-[1120px] flex flex-col items-center">

        <!-- Breadcrumbs -->
        <nav class="w-full flex items-center gap-2 text-xs text-brand-text/50 font-medium mb-8" aria-label="Breadcrumb">
          <a href="/blog" class="hover:text-white transition-colors">Blog</a>
          <span class="text-white/20">/</span>
          <span>{category}</span>
          <span class="text-white/20">/</span>
          <span class="text-white/60 truncate max-w-[240px] sm:max-w-none">{title}</span>
        </nav>

        <!-- Encabezado del artículo -->
        <header class="w-full max-w-[920px] flex flex-col items-start gap-5 mb-6">
          <!-- Chip de categoría -->
          <div class="px-3 py-1.5 rounded-full bg-brand-orange/15 border border-brand-orange/30">
            <span class="text-brand-orange font-semibold text-[11px] tracking-widest uppercase">{category}</span>
          </div>

          <!-- Título con gradiente -->
          <h1 class="text-[36px] sm:text-[48px] md:text-[60px] font-bold tracking-tight leading-[1.05] bg-linear-to-r from-white via-white via-55% to-brand-orange bg-clip-text text-transparent">
            {title}
          </h1>

          <!-- Extracto -->
          <p class="text-lg md:text-xl font-normal leading-normal text-brand-text/80 max-w-[800px]">
            {excerpt}
          </p>
        </header>

        <!-- Meta: fecha, tiempo de lectura y compartir -->
        <div class="w-full max-w-[920px] flex flex-col sm:flex-row sm:items-center justify-between py-6 border-t border-white/5 mb-16 gap-4">
          <div class="flex items-center gap-3.5 text-xs font-medium text-white/50">
            <span>{date}</span>
            <span class="w-1 h-1 rounded-full bg-white/20"></span>
            <span>{readTime}</span>
          </div>

          <!-- Botones de compartir -->
          <div class="flex items-center gap-2">
            {[
              { label: '𝕏', title: 'Share on X' },
              { label: 'in', title: 'Share on LinkedIn' },
              { label: '🔗', title: 'Copy link' },
              { label: '♡', title: 'Save' },
            ].map(({ label, title: t }) => (
              <button
                title={t}
                class="w-[38px] h-[38px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/80 hover:bg-white/10 transition-colors text-sm"
              >
                {label}
              </button>
            ))}
          </div>
        </div>

        <!-- Hero visual dinámico por color del post -->
        <div
          class="w-full max-w-[1120px] h-[250px] md:h-[420px] rounded-[32px] mb-16 overflow-hidden relative flex items-center justify-center"
          style="background: linear-gradient(180deg, #1A1029 0%, #0D0D23 100%);"
        >
          <div class="absolute w-[300px] md:w-[500px] h-[300px] md:h-[500px] rounded-full blur-[80px]" style={`background-color: ${color}40;`}></div>
          <div class="absolute w-[150px] h-[150px] bg-white/20 rounded-full blur-2xl"></div>
        </div>

        <!-- Cuerpo del artículo (Markdown) -->
        <article class="w-full max-w-[720px] article-prose">
          <Content />
        </article>

        <!-- Footer de compartir -->
        <footer class="w-full max-w-[720px] py-16">
          <div class="w-full h-px bg-white/10 mb-7"></div>
          <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
            <span class="text-[11px] font-semibold text-brand-text/60 tracking-widest uppercase">Share this article</span>
            <div class="flex items-center gap-2.5 flex-wrap justify-center">
              {['Twitter', 'LinkedIn', 'Copy link', 'Save'].map((label) => (
                <button class="px-[18px] py-2.5 rounded-full border border-white/10 text-xs font-medium hover:bg-white/5 transition-colors">
                  {label}
                </button>
              ))}
            </div>
          </div>
          <div class="w-full h-px bg-white/10 mt-7"></div>
        </footer>

        <!-- Autor -->
        <div class="w-full max-w-[720px] mb-24">
          <AuthorCard />
        </div>

        <!-- Posts relacionados -->
        {relatedPosts.length > 0 && (
          <div class="w-full max-w-[1120px] flex flex-col items-center mb-24">
            <div class="flex flex-col items-center text-center gap-3 mb-10">
              <span class="text-brand-orange text-xs font-semibold tracking-widest uppercase">Keep Exploring</span>
              <h2 class="text-white text-4xl font-bold">Related writings</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full">
              {relatedPosts.map((rPost) => (
                <BlogCard
                  title={rPost.title}
                  excerpt={rPost.excerpt}
                  date={rPost.date}
                  readTime={rPost.readTime}
                  category={rPost.category}
                  url={rPost.url}
                  color={rPost.color}
                />
              ))}
            </div>
          </div>
        )}

        <!-- Newsletter CTA -->
        <CTANewsletter />

      </div>
    </main>

    <Footer />
  </div>
</Layout>
