---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import CTANewsletter from '../../components/CTANewsletter.astro';
import BlogCard from '../../components/BlogCard.astro';
import BackgroundGlowsArticle from '../../components/BackgroundGlowsArticle.astro';

export async function getStaticPaths() {
  const posts = import.meta.glob('../../posts/*.md', { eager: true });

  return Object.entries(posts).map(([path, post]: [string, any]) => {
    const slug = path.split('/').pop()?.replace('.md', '');
    return { params: { slug }, props: { post } };
  });
}

const { post } = Astro.props;
const { title, excerpt, category, date, readTime, color } = post.frontmatter;
const Content = post.default;

// Posts relacionados: todos excepto el actual (máx. 3)
const allPosts = import.meta.glob('../../posts/*.md', { eager: true });
const relatedPosts = Object.entries(allPosts)
  .filter(([, p]: [string, any]) => p.frontmatter.title !== title)
  .slice(0, 3)
  .map(([path, p]: [string, any]) => ({
    ...p.frontmatter,
    url: `/blog/${path.split('/').pop()?.replace('.md', '')}`,
  }));
---

<Layout title={`${title} - Tokidev Blog`} description={excerpt}>
  <!-- Glows extendidos para artículos largos -->
  <BackgroundGlowsArticle slot="background" />

  <div class="relative w-full max-w-[1440px] mx-auto min-h-screen pt-28">
    <Navbar />

    <main class="w-full flex flex-col items-center pb-24">
      <div class="w-[92%] max-w-[1120px] flex flex-col items-center">

        <!-- Breadcrumbs -->
        <nav class="w-full flex items-center gap-2 text-xs text-[#a0a0b4] font-medium mb-8" aria-label="Breadcrumb">
          <a href="/blog" class="hover:text-white transition-colors">Blog</a>
          <span class="text-white/20">/</span>
          <span>{category}</span>
          <span class="text-white/20">/</span>
          <span class="text-white/60 truncate max-w-[240px] sm:max-w-none">{title}</span>
        </nav>

        <!-- Encabezado del artículo -->
        <header class="w-full max-w-[1120px] flex flex-col items-start gap-5 mb-6">
          <!-- Chip de categoría -->
          <div class="bg-white/5 border border-white/10 px-3.5 py-1.5 rounded-full backdrop-blur-md flex items-center justify-center">
            <span class="font-mono font-semibold text-[10.5px] text-[#DA2984] tracking-[0.315px] uppercase">{category}</span>
          </div>

          <!-- Título con gradiente a magenta oficial -->
          <h1 class="text-[36px] sm:text-[48px] md:text-[56px] font-bold tracking-tight leading-[1.1] bg-gradient-to-r from-white via-white via-[70%] to-[#DA2984] bg-clip-text text-transparent w-full">
            {title}
          </h1>

          <!-- Extracto -->
          <p class="text-[17px] sm:text-[18px] font-normal leading-relaxed text-[#a0a0b4] w-full">
            {excerpt}
          </p>
        </header>

        <!-- Meta: fecha, tiempo de lectura y compartir -->
        <div class="w-full max-w-[1120px] flex flex-col sm:flex-row sm:items-center justify-between py-6 border-t border-white/10 mb-16 gap-4">
          <div class="flex items-center gap-3.5 text-xs font-mono text-white/50">
            <span>{date}</span>
            <span class="w-1 h-1 rounded-full bg-white/20"></span>
            <span>{readTime}</span>
          </div>

          <!-- Botones de compartir estilizados a 40px con esquinas de 12px -->
          <div class="flex items-center gap-2">
            {[
              { label: '𝕏', title: 'Share on X' },
              { label: 'in', title: 'Share on LinkedIn' },
              { label: '🔗', title: 'Copy link' },
              { label: '♡', title: 'Save' },
            ].map(({ label, title: t }) => (
              <button
                title={t}
                class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-white/80 hover:bg-white/10 hover:border-white/20 hover:scale-105 transition-all duration-300 text-sm cursor-pointer"
              >
                {label}
              </button>
            ))}
          </div>
        </div>

        <!-- Portada visual dinámica por categoría (Figma 104:1412 / 104:1427) -->
        <div
          class="w-full max-w-[1120px] h-[250px] md:h-[440px] rounded-[20px] mb-16 overflow-hidden relative flex items-center justify-center shadow-2xl shadow-purple-950/20"
          style={`background: ${
            category.toLowerCase().includes('engineering') ? 'linear-gradient(139.958deg, rgb(46, 41, 140) 14.085%, rgb(158, 26, 133) 84.507%)' :
            category.toLowerCase().includes('career') ? 'linear-gradient(139.958deg, rgb(199, 33, 102) 14.085%, rgb(250, 128, 56) 84.507%)' :
            category.toLowerCase().includes('distributed') ? 'linear-gradient(139.958deg, rgb(77, 33, 153) 14.085%, rgb(204, 41, 115) 84.507%)' :
            category.toLowerCase().includes('source') ? 'linear-gradient(139.958deg, rgb(33, 77, 140) 14.085%, rgb(140, 31, 158) 84.507%)' :
            category.toLowerCase().includes('thoughts') ? 'linear-gradient(139.958deg, rgb(140, 31, 128) 14.085%, rgb(242, 115, 64) 84.507%)' :
            'linear-gradient(139.958deg, rgb(115, 26, 199) 14.085%, rgb(242, 107, 56) 84.507%)'
          }`}
        >
          <span class="absolute top-4 right-6 font-mono text-[10px] text-white/50 tracking-[0.2px] select-none pointer-events-none">
            FOTO ▦
          </span>
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/10 to-[#050510]/80 z-0"></div>
          <div class="absolute w-[200px] h-[200px] bg-white/10 rounded-full blur-3xl z-10"></div>
        </div>

        <!-- Cuerpo del artículo (Markdown) -->
        <article class="w-full max-w-[1120px] article-prose">
          <Content />
        </article>

        <!-- Footer de compartir -->
        <footer class="w-full max-w-[1120px] py-16">
          <div class="w-full h-px bg-white/10 mb-7"></div>
          <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
            <span class="text-[11px] font-semibold text-brand-text/60 tracking-widest uppercase">Share this article</span>
            <div class="flex items-center gap-2.5 flex-wrap justify-center">
              {['Twitter', 'LinkedIn', 'Copy link', 'Save'].map((label) => (
                <button class="px-[18px] py-2.5 rounded-full border border-white/10 text-xs font-medium hover:bg-white/5 hover:border-white/20 transition-all hover:scale-102 duration-300 cursor-pointer">
                  {label}
                </button>
              ))}
            </div>
          </div>
          <div class="w-full h-px bg-white/10 mt-7"></div>
        </footer>

        <!-- Autor -->
        <div class="w-full max-w-[1120px] mb-24">
          <AuthorCard />
        </div>

        <!-- Posts relacionados -->
        {relatedPosts.length > 0 && (
          <div class="w-full max-w-[1120px] flex flex-col items-center mb-24">
            <div class="flex flex-col items-center text-center gap-3.5 mb-10">
              <span class="text-[#DA2984] text-xs font-semibold tracking-widest uppercase">Keep Exploring</span>
              <h2 class="text-white text-3xl sm:text-4xl font-bold tracking-tight">Related writings</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full">
              {relatedPosts.map((rPost) => (
                <BlogCard
                  title={rPost.title}
                  excerpt={rPost.excerpt}
                  date={rPost.date}
                  readTime={rPost.readTime}
                  category={rPost.category}
                  url={rPost.url}
                  color={rPost.color}
                />
              ))}
            </div>
          </div>
        )}

      </div>
    </main>

    <Footer />
  </div>
</Layout>
