---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import CTANewsletter from '../../components/CTANewsletter.astro';
import BlogCard from '../../components/BlogCard.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = import.meta.glob('../../posts/*.md', { eager: true });
  
  return Object.entries(posts).map(([path, post]: [string, any]) => {
    // Extract `post-1` from `.../posts/post-1.md`
    const slug = path.split('/').pop()?.replace('.md', '');
    return {
      params: { slug },
      props: { post }
    };
  });
}

const { post } = Astro.props;
const { title, excerpt, category, date, readTime, color } = post.frontmatter;
const Content = post.default;

// Get 3 related posts for the bottom "Keep Exploring" grid
const allPostsParams = await import.meta.glob('../../posts/*.md', { eager: true });
const relatedPosts = Object.values(allPostsParams)
  .filter((p: any) => p.frontmatter.title !== title)
  .slice(0, 3);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Tokidev Blog</title>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');
      
      body {
          font-family: 'Inter', sans-serif;
          background-color: #0a111a; /* specific Figma bg for article */
          color: #ffffff;
      }
      
      /* 
         Markdown Typography Styles 
         This handles the raw tags output by Astro's <Content /> and also raw HTML mimicking Figma.
      */
      .article-prose {
        color: #c6cad0;
        font-size: 17px;
        line-height: 29px;
      }
      .article-prose p {
        margin-bottom: 1.5rem;
      }
      .article-prose h2 {
        color: #ffffff;
        font-size: 26px;
        font-weight: 700;
        letter-spacing: -0.48px;
        line-height: 1.25;
        margin-top: 2rem;
        margin-bottom: 1rem;
      }
      @media (min-width: 768px) {
        .article-prose h2 {
          font-size: 32px;
          line-height: 38px;
        }
      }
      .article-prose ul {
        list-style: none;
        padding-left: 0;
        margin-bottom: 1.5rem;
      }
      .article-prose li {
        position: relative;
        padding-left: 24px;
        margin-bottom: 8px;
      }
      .article-prose li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 10px;
        width: 8px;
        height: 8px;
        background-color: #f5a623;
        border-radius: 50%;
      }
      .article-prose strong {
        color: #ffffff;
        font-weight: 600;
      }
    </style>
  </head>
  <body class="antialiased selection:bg-brand-orange/30 overflow-x-hidden">
    <div class="relative w-full">
      
      <!-- Abstract Article Background Glows -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none -z-50">
        <!-- Top Left Orange -->
        <div class="absolute -top-[120px] -left-[160px] w-[540px] h-[540px] bg-brand-orange/20 blur-[120px] rounded-full"></div>
        <!-- Right Yellow -->
        <div class="absolute top-[600px] left-[960px] w-[460px] h-[460px] bg-brand-yellow/15 blur-[120px] rounded-full"></div>
        <!-- Left Purple -->
        <div class="absolute top-[1800px] -left-[220px] w-[640px] h-[640px] bg-brand-purple/20 blur-[130px] rounded-full"></div>
      </div>

      <div class="relative w-full max-w-[1440px] mx-auto min-h-screen pt-28">
        <Navbar />
        
        <main class="w-full flex flex-col items-center pb-24">
          
          <!-- Width 1280px wrapper for general centering -->
          <div class="w-[92%] max-w-[1280px] flex flex-col items-center">
            
            <!-- Breadcrumbs -->
            <div class="w-full max-w-[1120px] flex items-center gap-2.5 text-[13px] text-brand-text/50 font-medium mb-8">
              <span>Blog</span>
              <span class="text-white/20">/</span>
              <span>{category}</span>
              <span class="text-white/20">/</span>
              <span class="text-white/60">{title}</span>
            </div>

            <!-- Article Header (920px width limit in Figma) -->
            <div class="w-full max-w-[920px] flex flex-col items-start gap-5 mb-6">
              
              <!-- Tag -->
              <div class="px-3 py-1.5 rounded-full bg-brand-orange/15 border border-brand-orange/30 whitespace-nowrap">
                <span class="text-brand-orange font-semibold text-[11px] tracking-[1.1px] uppercase">
                  {category}
                </span>
              </div>
              
              <!-- Title String (We simulate the gradient on the whole title for now) -->
              <h1 class="text-[36px] sm:text-[48px] md:text-[60px] font-bold tracking-[-1.5px] leading-[1.05] bg-linear-to-r from-white via-white via-55% to-brand-orange bg-clip-text text-transparent">
                {title}
              </h1>
              
              <!-- Excerpt -->
              <p class="text-[18px] md:text-[20px] font-normal leading-normal text-brand-text/80 max-w-[800px]">
                {excerpt}
              </p>

            </div>

            <!-- Meta Row -->
            <div class="w-full max-w-[920px] flex flex-col sm:flex-row sm:items-center justify-between py-6 border-t border-white/5 mb-16 gap-6">
              <div class="flex items-center gap-[14px]">
                <span class="text-[13px] font-medium text-white/50">{date}</span>
                <span class="w-[3px] h-[3px] rounded-full bg-white/20"></span>
                <span class="text-[13px] font-medium text-white/50">{readTime}</span>
              </div>

              <!-- Share Buttons -->
              <div class="flex items-center gap-2">
                <button class="w-[38px] h-[38px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/80 hover:bg-white/10 transition">𝕏</button>
                <button class="w-[38px] h-[38px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/80 hover:bg-white/10 transition">in</button>
                <button class="w-[38px] h-[38px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/80 hover:bg-white/10 transition">🔗</button>
                <button class="w-[38px] h-[38px] rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/80 hover:bg-white/10 transition">♡</button>
              </div>
            </div>

            <!-- Hero Visual (Dynamic based on Color) -->
            <div class="w-full max-w-[1120px] h-[250px] md:h-[420px] rounded-[32px] mb-16 overflow-hidden relative flex items-center justify-center" style={`background: linear-gradient(180deg, #1A1029 0%, #0D0D23 100%);`}>
              <div class="absolute w-[300px] md:w-[500px] h-[300px] md:h-[500px] rounded-full blur-[80px]" style={`background-color: ${color}40;`}></div>
              <div class="absolute w-[150px] h-[150px] bg-white/20 rounded-full blur-2xl"></div>
            </div>

            <!-- Markdown Content Body -->
            <div class="w-full max-w-[720px] article-prose">
              <Content />
            </div>

            <!-- Share Formatting Footer -->
            <div class="w-full max-w-[720px] py-16">
              <div class="w-full h-px bg-white/10 mb-7"></div>
              <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
                <span class="text-[11px] font-semibold text-[#c6cad0] tracking-[2px] uppercase">
                  Share this article
                </span>
                <div class="flex items-center gap-2.5">
                  <button class="px-[18px] py-[10px] rounded-full border border-white/10 text-[13px] font-medium hover:bg-white/5 transition">Twitter</button>
                  <button class="px-[18px] py-[10px] rounded-full border border-white/10 text-[13px] font-medium hover:bg-white/5 transition">LinkedIn</button>
                  <button class="px-[18px] py-[10px] rounded-full border border-white/10 text-[13px] font-medium hover:bg-white/5 transition">Copy link</button>
                  <button class="px-[18px] py-[10px] rounded-full border border-white/10 text-[13px] font-medium hover:bg-white/5 transition">Save</button>
                </div>
              </div>
              <div class="w-full h-px bg-white/10 mt-7"></div>
            </div>

            <!-- Author Wrapper -->
            <div class="w-full max-w-[720px] mb-24">
              <AuthorCard />
            </div>

            <!-- Related Writings -->
            <div class="w-full max-w-[1120px] flex flex-col items-center mb-24">
              <div class="flex flex-col items-center text-center gap-3 mb-10">
                <span class="text-brand-orange text-[12px] font-semibold tracking-[3px] uppercase">Keep Exploring</span>
                <h3 class="text-white text-[36px] font-bold">Related writings</h3>
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full">
                {relatedPosts.map((rPost: any) => (
                  <BlogCard 
                    title={rPost.frontmatter.title}
                    excerpt={rPost.frontmatter.excerpt}
                    date={rPost.frontmatter.date}
                    readTime={rPost.frontmatter.readTime}
                    category={rPost.frontmatter.category}
                    url={`/blog/${rPost.file.split('/').pop().replace('.md', '')}`}
                    color={rPost.frontmatter.color}
                  />
                ))}
              </div>
            </div>

            <!-- Newsletter CTA -->
            <CTANewsletter />

          </div>
        </main>
        
        <Footer />
      </div>
    </div>
  </body>
</html>
