---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import BackgroundGlows from "../components/BackgroundGlows.astro";
import BlogCard from "../components/BlogCard.astro";
import FeaturedBlogPost from "../components/FeaturedBlogPost.astro";
import CTABlog from "../components/CTABlog.astro";

// Obtiene todos los posts de markdown con Vite's eager glob
const posts = Object.values(
  import.meta.glob("../posts/*.md", { eager: true }),
) as any[];

// Formateamos los posts para construir dinámicamente sus rutas relativas correctas
const formattedPosts = posts.map((post) => {
  const slug = post.file.split('/').pop()?.replace('.md', '');
  return {
    ...post,
    url: `/blog/${slug}`,
  };
});

const sortedPosts = [...formattedPosts].reverse();

// El post destacado es el primero que contiene 'post-1' o por defecto el primero
const featuredPost =
  sortedPosts.find((p) => p.url.includes("post-1")) ?? sortedPosts[0];
const gridPosts = sortedPosts.filter((p) => p !== featuredPost);

// Categorías únicas extraídas dinámicamente de los posts
const categories = [
  "All",
  ...new Set(sortedPosts.map((p) => p.frontmatter.category as string)),
];
---

<Layout
  title="Blog - Tokidev | Senior Fullstack Engineer"
  description="Essays, deep-dives, and postmortems on engineering, distributed systems, and the craft of building software that lasts."
>
  <!-- Capa de fondo -->
  <BackgroundGlows slot="background" />

  <div class="relative w-full max-w-[1440px] mx-auto min-h-screen">
    <Navbar />

    <main
      class="flex flex-col items-center w-full relative z-10 pt-32 lg:pt-40"
    >
      <!-- Blog Hero (Figma Node 104:1389) -->
      <section class="w-full flex justify-center mb-14 lg:mb-16">
        <div class="w-[92%] max-w-[1120px] flex flex-col items-start gap-5">
          <p
            class="font-mono font-medium text-xs tracking-[0.36px] text-[#DA2984] uppercase"
          >
            THE BLOG ★
          </p>
          <h1
            class="text-4xl sm:text-5xl lg:text-[56px] font-bold tracking-tight leading-tight text-white max-w-[860px]"
          >
            Notes from the trenches of building real software.
          </h1>
          <p
            class="text-[#a0a0b4] text-base sm:text-lg lg:text-[18px] leading-relaxed max-w-[640px]"
          >
            Essays, deep-dives, and postmortems on engineering, distributed
            systems, and the craft of building software that lasts.
          </p>
        </div>
      </section>

      <!-- Filtros y búsqueda (Figma Node 104:1393) -->
      <section class="w-full flex justify-center mb-16">
        <div
          class="w-[92%] max-w-[1120px] flex flex-col items-start gap-[18px]"
        >
          <!-- Buscador (Figma Node 104:1394) -->
          <div
            class="w-full flex items-center px-[20px] py-[15px] rounded-[14px] bg-white/4 border border-white/10 backdrop-blur-xl gap-3"
          >
            <span
              class="text-[#a0a0b4] text-[18px] leading-none shrink-0 pointer-events-none select-none font-medium"
              >⌕</span
            >
            <input
              type="text"
              id="blog-search"
              placeholder="Search articles, topics, tags…"
              class="bg-transparent border-none outline-none text-[15px] text-[#a0a0b4] placeholder:text-[#a0a0b4] w-full font-normal"
            />
          </div>

          <!-- Chips de filtro (Figma Node 104:1397) -->
          <div
            class="flex flex-wrap items-center gap-[10px] w-full"
            id="filter-chips"
          >
            {
              categories.map((cat) => (
                <button
                  class:list={[
                    "filter-btn px-[16px] py-[9px] rounded-full text-[13px] font-semibold transition-colors cursor-pointer",
                    cat === "All"
                      ? "bg-gradient-to-r from-[#da2984] to-[#a406e9] text-white border-transparent"
                      : "bg-white/5 border border-white/10 text-[#a0a0b4] hover:bg-white/10 hover:text-white",
                  ]}
                  data-filter={cat}
                >
                  {cat}
                </button>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Post destacado -->
      {
        featuredPost && (
          <section class="w-full flex justify-center mb-16 lg:mb-24">
            <FeaturedBlogPost
              title={featuredPost.frontmatter.title}
              excerpt={featuredPost.frontmatter.excerpt}
              date={featuredPost.frontmatter.date}
              author="Tokidev"
              readTime={featuredPost.frontmatter.readTime}
              category={featuredPost.frontmatter.category}
              url={featuredPost.url}
            />
          </section>
        )
      }

      <!-- Grid de posts -->
      <section class="w-full flex justify-center pb-24 lg:pb-32">
        <div class="w-[92%] max-w-[1120px]">
          <div class="flex items-center gap-2 mb-8">
            <div class="w-6 h-px bg-[#DA2984]"></div>
            <span
              class="text-[#DA2984] text-[11px] font-semibold tracking-[1.54px] uppercase"
              >Latest Posts ★</span
            >
          </div>

          <!-- Contenedor del grid filtrable -->
          <div
            id="blog-grid"
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
          >
            {
              gridPosts.map((post) => (
                <BlogCard
                  title={post.frontmatter.title}
                  excerpt={post.frontmatter.excerpt}
                  date={post.frontmatter.date}
                  readTime={post.frontmatter.readTime}
                  category={post.frontmatter.category}
                  url={post.url}
                  color={post.frontmatter.color}
                />
              ))
            }
          </div>

          <!-- Estado vacío al filtrar -->
          <div
            id="no-results"
            class="hidden w-full py-20 flex-col items-center justify-center gap-4 text-center"
          >
            <span class="text-5xl">🔍</span>
            <p class="text-brand-text/50 text-base font-medium">
              No articles match your search.
            </p>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<script>
  const searchInput = document.getElementById(
    "blog-search",
  ) as HTMLInputElement;
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".blog-card-element");
  const noResults = document.getElementById("no-results");

  let currentSearch = "";
  let currentCategory = "All";

  function filterPosts() {
    let visibleCount = 0;

    cards.forEach((card) => {
      const title = card.querySelector("h3")?.textContent?.toLowerCase() ?? "";
      const excerpt = card.querySelector("p")?.textContent?.toLowerCase() ?? "";
      const category = card.getAttribute("data-category") ?? "";

      const matchesSearch =
        currentSearch === "" ||
        title.includes(currentSearch) ||
        excerpt.includes(currentSearch);

      const matchesCategory =
        currentCategory === "All" || category === currentCategory;

      const visible = matchesSearch && matchesCategory;
      card.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    });

    if (noResults) {
      noResults.classList.toggle("hidden", visibleCount > 0);
    }
  }

  // Búsqueda en tiempo real
  searchInput?.addEventListener("input", (e) => {
    currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
    filterPosts();
  });

  // Filtro por categoría
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      currentCategory = btn.getAttribute("data-filter") ?? "All";

      // Actualiza estilos de chips activos/inactivos (Figma Node 104:1398 y 104:1400)
      filterBtns.forEach((b) => {
        const isActive = b === btn;
        b.className = isActive
          ? "filter-btn px-[16px] py-[9px] rounded-full text-[13px] font-semibold transition-colors bg-gradient-to-r from-[#da2984] to-[#a406e9] text-white border-transparent cursor-pointer"
          : "filter-btn px-[16px] py-[9px] rounded-full text-[13px] font-semibold transition-colors bg-white/5 border border-white/10 text-[#a0a0b4] hover:bg-white/10 hover:text-white cursor-pointer";
      });

      filterPosts();
    });
  });
</script>
