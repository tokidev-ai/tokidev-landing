---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import BackgroundGlows from "../components/BackgroundGlows.astro";
import BlogCard from "../components/BlogCard.astro";
import FeaturedBlogPost from "../components/FeaturedBlogPost.astro";
import CTABlog from "../components/CTABlog.astro";

// Obtiene todos los posts de markdown con Vite's eager glob
const posts = Object.values(
  import.meta.glob("../posts/*.md", { eager: true }),
) as any[];
const sortedPosts = [...posts].reverse();

// El post destacado es siempre el primero (post-1)
const featuredPost =
  sortedPosts.find((p) => p.url?.includes("post-1")) ?? sortedPosts[0];
const gridPosts = sortedPosts.filter((p) => p !== featuredPost);

// Categorías únicas extraídas dinámicamente de los posts
const categories = [
  "All",
  ...new Set(sortedPosts.map((p) => p.frontmatter.category as string)),
];
---

<Layout
  title="Blog - Tokidev | Senior Fullstack Engineer"
  description="Essays, deep-dives, and postmortems on engineering, distributed systems, and the craft of shipping products that actually work."
>
  <!-- Capa de fondo -->
  <BackgroundGlows slot="background" />

  <div class="relative w-full max-w-[1440px] mx-auto min-h-screen">
    <Navbar />

    <main
      class="flex flex-col items-center w-full relative z-10 pt-32 lg:pt-40"
    >
      <!-- Blog Hero -->
      <section class="w-full flex justify-center mb-14 lg:mb-16">
        <div class="w-[92%] max-w-[1120px] flex flex-col items-start">
          <div class="flex items-center gap-2 mb-6">
            <div class="h-px w-10 bg-linear-to-r from-brand-orange to-transparent"></div>
            <span
              class="font-mono font-medium text-[#ff8a5c] text-sm tracking-[2.88px] uppercase"
              >The Blog ★</span
            >
          </div>
          <h1
            class="text-[44px] md:text-[56px] lg:text-[64px] font-bold tracking-tight leading-[1.05] bg-hero-title bg-clip-text text-transparent mb-5 max-w-[800px]"
          >
            Notes from the trenches<br />of building real software.
          </h1>
          <p
            class="text-brand-text/80 text-base md:text-[17px] leading-relaxed max-w-[620px]"
          >
            Essays, deep-dives, and postmortems on engineering, distributed
            systems, and the craft of shipping products that actually work.
          </p>
        </div>
      </section>

      <!-- Filtros y búsqueda -->
      <section class="w-full flex justify-center mb-16">
        <div
          class="w-[92%] max-w-[1120px] flex flex-col lg:flex-row items-center justify-between gap-6"
        >
          <!-- Buscador -->
          <div
            class="w-full lg:w-[420px] h-btn-px rounded-full bg-white/5 border border-white/10 backdrop-blur-xl flex items-center px-5 gap-3"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-white/50 shrink-0"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input
              type="text"
              id="blog-search"
              placeholder="Search articles, topics, tags..."
              class="bg-transparent border-none outline-none text-sm text-white/50 placeholder:text-white/50 w-full font-medium"
            />
          </div>

          <!-- Chips de filtro (generados dinámicamente) -->
          <div class="flex flex-wrap items-center gap-2.5" id="filter-chips">
            {
              categories.map((cat) => (
                <button
                  class:list={[
                    "filter-btn px-4 py-2 rounded-full text-xs font-medium transition-colors",
                    cat === "All"
                      ? "bg-brand-orange/15 border border-brand-orange/40 text-white flex items-center gap-2"
                      : "bg-white/5 border border-white/10 text-brand-text/80 hover:bg-white/10 hover:text-white",
                  ]}
                  data-filter={cat}
                >
                  {cat === "All" && (
                    <span class="w-1.5 h-1.5 rounded-full bg-white" />
                  )}
                  {cat}
                </button>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Post destacado -->
      {
        featuredPost && (
          <section class="w-full flex justify-center mb-16 lg:mb-24">
            <FeaturedBlogPost
              title={featuredPost.frontmatter.title}
              excerpt={featuredPost.frontmatter.excerpt}
              date={featuredPost.frontmatter.date}
              author="Tokidev"
              readTime={featuredPost.frontmatter.readTime}
              category={featuredPost.frontmatter.category}
              url="/blog/post-1"
            />
          </section>
        )
      }

      <!-- Grid de posts -->
      <section class="w-full flex justify-center pb-24 lg:pb-32">
        <div class="w-[92%] max-w-[1120px]">
          <div class="flex items-center gap-2 mb-8">
            <div class="w-6 h-px bg-brand-orange"></div>
            <span
              class="text-brand-orange text-[11px] font-semibold tracking-[1.54px] uppercase"
              >Latest Posts ★</span
            >
          </div>

          <!-- Contenedor del grid filtrable -->
          <div
            id="blog-grid"
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
          >
            {
              gridPosts.map((post) => (
                <BlogCard
                  title={post.frontmatter.title}
                  excerpt={post.frontmatter.excerpt}
                  date={post.frontmatter.date}
                  readTime={post.frontmatter.readTime}
                  category={post.frontmatter.category}
                  url={post.url}
                  color={post.frontmatter.color}
                />
              ))
            }
          </div>

          <!-- Estado vacío al filtrar -->
          <div
            id="no-results"
            class="hidden w-full py-20 flex-col items-center justify-center gap-4 text-center"
          >
            <span class="text-5xl">🔍</span>
            <p class="text-brand-text/50 text-base font-medium">
              No articles match your search.
            </p>
          </div>
        </div>
      </section>

      <CTABlog />
    </main>

    <Footer />
  </div>
</Layout>

<script>
  const searchInput = document.getElementById(
    "blog-search",
  ) as HTMLInputElement;
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".blog-card-element");
  const noResults = document.getElementById("no-results");

  let currentSearch = "";
  let currentCategory = "All";

  function filterPosts() {
    let visibleCount = 0;

    cards.forEach((card) => {
      const title = card.querySelector("h3")?.textContent?.toLowerCase() ?? "";
      const excerpt = card.querySelector("p")?.textContent?.toLowerCase() ?? "";
      const category = card.getAttribute("data-category") ?? "";

      const matchesSearch =
        currentSearch === "" ||
        title.includes(currentSearch) ||
        excerpt.includes(currentSearch);

      const matchesCategory =
        currentCategory === "All" || category === currentCategory;

      const visible = matchesSearch && matchesCategory;
      card.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    });

    if (noResults) {
      noResults.classList.toggle("hidden", visibleCount > 0);
    }
  }

  // Búsqueda en tiempo real
  searchInput?.addEventListener("input", (e) => {
    currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
    filterPosts();
  });

  // Filtro por categoría
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      currentCategory = btn.getAttribute("data-filter") ?? "All";

      // Actualiza estilos de chips activos/inactivos
      filterBtns.forEach((b) => {
        const isActive = b === btn;
        b.className = isActive
          ? "filter-btn px-4 py-2 rounded-full text-xs font-medium transition-colors bg-brand-orange/15 border border-brand-orange/40 text-white flex items-center gap-2"
          : "filter-btn px-4 py-2 rounded-full text-xs font-medium transition-colors bg-white/5 border border-white/10 text-brand-text/80 hover:bg-white/10 hover:text-white";

        // Dot indicator solo en el activo
        const existingDot = b.querySelector("span");
        if (isActive && !existingDot) {
          b.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-white"></span> ${b.textContent?.trim()}`;
        } else if (!isActive && existingDot) {
          b.textContent = b.textContent?.trim() ?? "";
        }
      });

      filterPosts();
    });
  });
</script>
