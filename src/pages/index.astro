---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Capabilities from "../components/Capabilities.astro";
import FeaturedProject from "../components/FeaturedProject.astro";
import Speaking from "../components/Speaking.astro";
import Experience from "../components/Experience.astro";
import Community from "../components/Community.astro";
import Testimonials from "../components/Testimonials.astro";
import Mentorship from "../components/Mentorship.astro";
import FreeResources from "../components/FreeResources.astro";
import LatestBlog from "../components/LatestBlog.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import BackgroundGlows from "../components/BackgroundGlows.astro";
import TechMarquee from "../components/TechMarquee.astro";
---

<Layout
  title="Tokidev | Senior Fullstack Engineer"
  description="Senior Fullstack Engineer specializing in scalable architectures, clean code, and shipping products that work."
>
  <BackgroundGlows slot="background" />

  <div class="relative w-full mx-auto min-h-screen overflow-x-hidden">
    <Navbar />

    <main class="w-full relative z-10">
      <!-- Hero Section (Constrained) -->
      <div class="w-[92%] max-w-[1120px] mx-auto">
        <Hero />
      </div>

      <!-- Full Width Marquee -->
      <TechMarquee />

      <!-- Rest of the Sections (Constrained en orden exacto de Figma 01 a 09) -->
      <div class="w-[92%] max-w-[1120px] mx-auto flex flex-col items-center">
        <Capabilities />
        <FeaturedProject />
        <Speaking />
        <Experience />
        <Community />
        <Mentorship />
        <FreeResources />
        <Testimonials />
        <LatestBlog />
        <CTA />
        <Footer />
      </div>
    </main>
  </div>
</Layout>
