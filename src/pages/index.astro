---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import FeaturedProject from '../components/FeaturedProject.astro';
import Community from '../components/Community.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import BackgroundGlows from '../components/BackgroundGlows.astro';
import TechMarquee from '../components/TechMarquee.astro';
---

<Layout
  title="Tokidev | Senior Fullstack Engineer"
  description="Senior Fullstack Engineer specializing in scalable architectures, clean code, and shipping products that work."
>
  <BackgroundGlows slot="background" />

  <div class="relative w-full max-w-[1440px] mx-auto min-h-screen overflow-x-hidden">
    <Navbar />

    <main class="w-full relative z-10">
      <!-- Hero Section (Constrained) -->
      <div class="w-[92%] max-w-[1120px] mx-auto">
        <Hero />
      </div>

      <!-- Full Width Marquee -->
      <TechMarquee />

      <!-- Rest of the Sections (Constrained) -->
      <div class="w-[92%] max-w-[1120px] mx-auto flex flex-col items-center">
        <Experience />
        <FeaturedProject />
        <Community />
        <Testimonials />
        <CTA />
        <Footer />
      </div>
    </main>
  </div>
</Layout>
