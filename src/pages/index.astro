---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import FeaturedProject from '../components/FeaturedProject.astro';
import Community from '../components/Community.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import BackgroundGlows from '../components/BackgroundGlows.astro';
---

<Layout title="Tokidev | Senior Fullstack Engineer">
	<div class="relative w-full overflow-x-hidden">
		<!-- Background Glows Layer (Full Width) -->
		<BackgroundGlows />
		
		<div class="relative w-full max-w-[1440px] mx-auto min-h-screen">
			<Navbar />
			
			<main class="flex flex-col items-center w-full relative z-10">
				<Hero />
				<Experience />
				<FeaturedProject />
				<Community />
				<Testimonials />
				<CTA />
			</main>

			<Footer />
		</div>
	</div>
</Layout>

<style is:global>
	/* Ensure no horizontal scroll on any device */
	html, body {
		overflow-x: hidden;
		width: 100%;
		position: relative;
	}
</style>
