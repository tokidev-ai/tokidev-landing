---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import FeaturedProject from '../components/FeaturedProject.astro';
import Community from '../components/Community.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Tokidev | Senior Fullstack Engineer">
	<Navbar />
	
	<main class="flex flex-col items-center w-full">
		<Hero />
		<Experience />
		<FeaturedProject />
		<Community />
		<Testimonials />
		<CTA />
	</main>

	<Footer />
</Layout>

<style is:global>
	/* Background Glows (Global) */
	body::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			radial-gradient(circle at 20% 20%, rgba(239, 108, 74, 0.05) 0%, transparent 40%),
			radial-gradient(circle at 80% 50%, rgba(123, 94, 167, 0.05) 0%, transparent 40%),
			radial-gradient(circle at 40% 80%, rgba(245, 166, 35, 0.05) 0%, transparent 40%);
		pointer-events: none;
		z-index: -20;
	}
</style>
