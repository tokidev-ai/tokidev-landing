---
/**
 * Community.astro
 * Componente de la sección 05 — Community & Awards.
 * Desacopla la fuente de datos importando communityAwards desde src/data/community.ts y mapea dinámicamente los íconos de lucide-astro.
 */
import CommunityCard from './CommunityCard.astro';
import { communityAwards } from '../data/community';
import { Users, Globe, Trophy, Zap } from 'lucide-astro';

const iconMap = {
  Users,
  Globe,
  Trophy,
  Zap
};
---

<section id="community" class="py-16 lg:py-24 w-full flex flex-col items-center">
  <!-- Cabecera de la Sección según Figma (nodo 66:1037) -->
  <div class="w-full flex flex-col gap-2.5 items-start mb-10">
    <p class="font-mono font-medium text-xs tracking-[0.6px] bg-clip-text text-transparent bg-gradient-to-r from-[#DA2984] to-[#A406E9] uppercase">
      05 — COMMUNITY & AWARDS
    </p>
    <h2 class="font-bold text-3xl sm:text-4xl lg:text-[40px] text-white tracking-tight">
      Beyond the code.
    </h2>
  </div>

  <!-- Grid Responsivo de 4 Tarjetas de Comunidad (nodo 66:1040) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 w-full">
    {communityAwards.map(award => (
      <CommunityCard 
        title={award.title}
        description={award.description}
        icon={iconMap[award.iconName]}
      />
    ))}
  </div>
</section>
