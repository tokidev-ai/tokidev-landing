---
/**
 * Testimonials.astro
 * Componente de la sección 06 — Testimonios.
 * Mantiene desacoplada la lista de testimonios en src/data/testimonials.ts y renderiza las tarjetas en 2 columnas con comillas gigantes.
 */
import { testimonials } from '../data/testimonials';
---

<section id="testimonials" class="py-16 lg:py-24 w-full flex flex-col items-center">
  <!-- Cabecera de la Sección según Figma (nodo 66:1107) -->
  <div class="w-full flex flex-col gap-2.5 items-start mb-10">
    <p class="font-mono font-medium text-xs tracking-[0.6px] bg-clip-text text-transparent bg-gradient-to-r from-[#DA2984] to-[#A406E9] uppercase">
      06 — TESTIMONIALS
    </p>
    <h2 class="font-bold text-3xl sm:text-4xl lg:text-[40px] text-white tracking-tight">
      What they say about Tokidev.
    </h2>
  </div>

  <!-- Grid Responsivo de 2 Tarjetas de Testimonio (nodo 66:1110) -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 w-full">
    {testimonials.map((test) => (
      <div class="bg-white/[0.03] border border-white/[0.08] rounded-[20px] p-8 sm:p-9 flex flex-col justify-between gap-5 relative overflow-hidden transition-all duration-300 hover:border-white/20 hover:bg-white/[0.05] group shadow-lg shadow-purple-950/10 min-h-[300px]">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#DA2984] to-[#A406E9] text-[56px] font-bold leading-none select-none">
          “
        </span>

        <p class="text-[#dcdce8] text-base sm:text-[17px] font-medium leading-[27px] flex-1">
          {test.text}
        </p>

        <div class="flex items-center gap-3.5 pt-2">
          <div class="w-11 h-11 rounded-full bg-gradient-to-r from-[#DA2984] to-[#A406E9] flex items-center justify-center text-white font-bold text-sm shadow-md shadow-purple-900/30 shrink-0">
            <span>{test.initials}</span>
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="font-semibold text-[15px] text-white tracking-tight">
              {test.author}
            </span>
            <span class="font-medium text-xs text-[#a0a0b4]">
              {test.role}
            </span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
