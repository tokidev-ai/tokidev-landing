---
import { Calendar } from "lucide-astro";
---

<div
  class="relative w-full max-w-5xl mx-auto rounded-3xl border border-[rgba(164,6,233,0.12)] overflow-hidden flex flex-col items-center justify-center p-8 lg:p-16"
  style="background-image: linear-gradient(152.4deg, rgb(15, 15, 18) 0%, rgb(26, 18, 48) 38.89%, rgb(42, 14, 85) 70.71%)"
>
  <!-- Content -->
  <div
    class="flex flex-col items-center text-center gap-8 z-10 w-full max-w-3xl"
  >
    <!-- Title -->
    <div class="font-bold text-3xl md:text-5xl leading-tight text-white">
      <p class="mb-2">Ready to build something great?</p>
      <p
        class="bg-clip-text bg-linear-to-r from-[#f53955] to-[#fa743f] text-transparent"
      >
        Let's talk.
      </p>
    </div>

    <!-- Description -->
    <p class="text-[#c6cad0] text-base md:text-lg leading-relaxed max-w-2xl">
      Code limpio, performance al 99 percentil y entregas que se sienten —
      listas para hoy.
    </p>

    <!-- Form -->
    <form class="w-full max-w-2xl flex flex-col gap-6 items-center">
      <div class="flex flex-col sm:flex-row gap-4 w-full">
        <div
          class="bg-white/95 border border-white/12 flex h-14 items-center px-6 rounded-full w-full sm:flex-1"
        >
          <input
            type="text"
            placeholder="Tu nombre"
            class="bg-transparent border-none outline-none w-full text-black placeholder-[#9aa0a6] text-base focus:ring-0"
            required
          />
        </div>
        <div
          class="bg-white/95 border border-white/12 flex h-14 items-center px-6 rounded-full w-full sm:flex-1"
        >
          <input
            type="email"
            placeholder="tu@email.com"
            class="bg-transparent border-none outline-none w-full text-black placeholder-[#9aa0a6] text-base focus:ring-0"
            required
          />
        </div>
      </div>

      <!-- CTA Button -->
      <button
        type="submit"
        class="w-full bg-linear-to-r from-[#f53955] to-[#fa743f] flex h-14 items-center justify-center gap-3 px-8 rounded-full shadow-[0px_12px_28px_-4px_rgba(245,57,85,0.35)] text-white text-base font-semibold hover:scale-[1.02] transition-transform cursor-pointer"
      >
        <Calendar size={18} />
        Schedule a Meeting
        <span class="ml-1">→</span>
      </button>
    </form>

    <!-- Footer Text -->
    <p class="text-[#8c8f9e] text-sm">
      Respondo en menos de 24h. Sin compromiso, solo conversamos.
    </p>
  </div>
</div>
