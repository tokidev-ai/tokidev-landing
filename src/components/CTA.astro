---
import { Calendar } from 'lucide-astro';
---

<section id="contact" class="py-24 flex justify-center relative">
  <!-- Glowing Background behind CTA -->
  <div class="absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 w-[400px] h-[200px] bg-brand-orange/20 blur-[130px] rounded-full -z-10"></div>

  <div class="relative w-[92%] lg:w-[96%] max-w-[1280px] min-h-[440px] rounded-[32px] border border-brand-border/15 overflow-hidden flex items-center justify-center">
    <!-- Glass Background -->
    <div class="absolute inset-0 bg-linear-to-br from-black/35 to-white/5 backdrop-blur-xl -z-10"></div>

    <!-- Decorative lines -->
    <div class="absolute inset-0 p-8 flex flex-col justify-between opacity-10 pointer-events-none">
        {[20, 45, 70, 95, 120].map((t) => (
             <div class="w-full h-px bg-brand-text" style={`top: ${t}px; absolute`}></div>
        ))}
        {[20, 45, 70, 95, 120].map((b) => (
             <div class="w-full h-px bg-brand-text" style={`bottom: ${b}px; absolute`}></div>
        ))}
    </div>

    <!-- Content -->
    <div class="flex flex-col items-center text-center gap-8 px-8 z-10 max-w-[800px]">
      <h2 class="text-[40px] md:text-[50px] font-bold tracking-[-0.8px] text-brand-text/90 leading-[1.2]">
        Ready to build something great? <br />
        <span class="text-brand-orange">Let’s talk.</span>
      </h2>
      
      <a href="https://calendly.com/pedroanze" target="_blank" rel="noopener noreferrer" 
         class="flex items-center gap-2.5 px-9 py-4 bg-linear-to-r from-brand-orange to-brand-yellow rounded-full text-[15px] font-bold text-white shadow-lg hover:scale-[1.05] transition-transform">
        <Calendar size={18} />
        Schedule a Meeting
        <span class="ml-1 opacity-70">→</span>
      </a>
    </div>
  </div>
</section>
