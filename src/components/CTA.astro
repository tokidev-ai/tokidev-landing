---
/**
 * CTA.astro
 * Componente de Llamado a la Acción final (Contacto / Agendar reunión).
 * Rediseñado con los colores de marca oficiales (púrpura, magenta, naranja) y botón directo hacia Calendly (sin formulario).
 */
import { Calendar } from 'lucide-astro';
import Button from './Button.astro';
---

<div
  id="contact"
  class="relative w-full rounded-[24px] lg:rounded-[32px] border border-[#DA2984]/40 overflow-hidden flex flex-col items-center justify-center p-8 lg:p-16 shadow-2xl shadow-purple-950/40 my-12"
  style="background: linear-gradient(152.4deg, rgba(15, 15, 18, 0.95) 0%, rgba(26, 18, 48, 0.95) 38.89%, rgba(42, 14, 85, 0.95) 70.71%)"
>
  <!-- Decoración luminosa de fondo -->
  <div class="absolute w-96 h-96 bg-brand-purple/20 blur-3xl rounded-full -top-20 -right-20 pointer-events-none"></div>
  <div class="absolute w-96 h-96 bg-brand-orange/15 blur-3xl rounded-full -bottom-20 -left-20 pointer-events-none"></div>

  <!-- Contenido Central -->
  <div class="flex flex-col items-center text-center gap-6 lg:gap-8 z-10 w-full max-w-3xl">
    <!-- Título Principal con Tonalidades de Marca -->
    <div class="font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight text-white tracking-tight">
      <p class="mb-1">Ready to build something great?</p>
      <p class="bg-clip-text text-transparent bg-gradient-to-r from-[#FA743F] via-[#DA2984] to-[#A406E9]">
        Let's talk.
      </p>
    </div>

    <!-- Descripción -->
    <p class="text-[#c6cad0] text-base lg:text-lg leading-relaxed max-w-2xl">
      Code limpio, performance al 99 percentil y entregas que se sienten — listas para hoy.
    </p>

    <!-- Botón de Acción Directa hacia Calendly (Reemplaza el formulario) -->
    <div class="pt-2 flex flex-col items-center gap-3">
      <Button 
        href="https://calendly.com" 
        target="_blank" 
        rel="noopener noreferrer"
        variant="primary" 
        size="lg"
        class="px-8 py-4 text-base sm:text-lg shadow-xl shadow-brand-red/30 hover:scale-105 transition-all"
      >
        <Calendar size={20} class="mr-1" />
        <span>Schedule a Meeting</span>
      </Button>
      
      <span class="font-mono font-medium text-[11px] text-[#8c8f9e] tracking-[0.22px] uppercase pt-1">
        CALENDLY ↗
      </span>
    </div>

    <!-- Texto de Cierre -->
    <p class="text-[#8c8f9e] text-sm pt-2">
      Respondo en menos de 24h. Sin compromiso, solo conversamos.
    </p>
  </div>
</div>
