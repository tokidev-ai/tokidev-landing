---
import {
  ArrowRight,
  Github,
  Linkedin,
  Instagram,
  Mail,
} from "lucide-astro";
---

<section
  id="about"
  class="relative pt-24 pb-12 lg:pt-32 lg:pb-20 flex justify-center"
>
  <div class="flex flex-col lg:flex-row items-center gap-12 z-10">
    <!-- Left Column -->
    <div
      class="flex flex-col items-center lg:items-start text-center lg:text-left gap-6 lg:gap-8 w-full lg:flex-1"
    >
      <div
        data-hero="badge"
        class="px-4 py-2 bg-white/7 backdrop-blur-md border border-white/12 rounded-full overflow-hidden inline-block"
      >
        <span
          class="text-xs font-semibold text-[#cce0ff] uppercase tracking-[1.65px]"
        >
          SENIOR FULLSTACK ENGINEER ★
        </span>
      </div>

      <h1
        data-hero="title"
        class="text-3xl sm:text-4xl lg:text-6xl font-medium leading-[1.1] lg:leading-[1.07] tracking-[-1.2px] lg:tracking-[-1.8px] bg-hero-title bg-clip-text text-transparent"
      >
        Your next product deserves an <span class="font-bold">engineer</span>,
        not just a <span class="font-bold">developer</span>.
      </h1>

      <div
        data-hero="desc"
        class="text-[#c6cad0] text-sm sm:text-base lg:text-lg leading-[1.6] max-w-[520px]"
      >
        <p>
          With over a decade of experience, I specialize in bridging complex
          backend architectures and high-performance frontend interfaces. My
          approach is rooted in clean code and developer experience.
        </p>
      </div>

      <div
        data-hero="actions"
        class="flex flex-col items-center lg:items-start gap-6 mt-2 w-full sm:w-auto"
      >
        <!-- Main CTA -->
        <a
          href="#contact"
          class="w-full sm:w-auto flex items-center justify-center gap-2.5 px-btn-px py-btn-py bg-white rounded-full text-sm font-semibold text-[#0f121a] hover:bg-zinc-200 transition-colors"
        >
          Let's Talk
          <ArrowRight size={18} />
        </a>

        <!-- Social Icons -->
        <div class="flex gap-3.5 items-start">
          <a
            href="https://github.com/tokidev-ai"
            target="_blank"
            rel="noopener noreferrer"
            class="backdrop-blur-[5px] bg-white/5 border border-white/10 flex items-center justify-center rounded-[14px] size-social-size hover:bg-white/10 transition-colors"
          >
            <Github size={22} class="text-white" />
          </a>
          <a
            href="https://www.linkedin.com/in/tokidev/"
            target="_blank"
            rel="noopener noreferrer"
            class="backdrop-blur-[5px] bg-white/5 border border-white/10 flex items-center justify-center rounded-[14px] size-social-size hover:bg-white/10 transition-colors"
          >
            <Linkedin size={22} class="text-white" />
          </a>
          <a
            href="https://www.instagram.com/tokidev.ai/"
            target="_blank"
            rel="noopener noreferrer"
            class="backdrop-blur-[5px] bg-white/5 border border-white/10 flex items-center justify-center rounded-[14px] size-social-size hover:bg-white/10 transition-colors"
          >
            <Instagram size={22} class="text-white" />
          </a>
          <a
            href="mailto:rodrigo.torricodelcastillo@gmail.com"
            class="backdrop-blur-[5px] bg-white/5 border border-white/10 flex items-center justify-center rounded-[14px] size-social-size hover:bg-white/10 transition-colors"
          >
            <Mail size={22} class="text-white" />
          </a>
        </div>
      </div>
    </div>

    <!-- Right Column (Glass Visual) -->
    <div
      data-hero="card"
      class="shrink-0 w-full max-w-[340px] sm:max-w-[400px] lg:w-[400px] xl:w-[452px] h-[320px] sm:h-[380px] lg:h-[416px] rounded-[40px] lg:rounded-[56px] border-2 lg:border-[3px] border-white/40 bg-hero-card backdrop-blur-2xl relative overflow-hidden group"
    >
      <!-- Visual decoration inside glass -->
      <div
        class="absolute -top-10 -right-10 w-40 h-40 bg-brand-orange/30 blur-3xl rounded-full group-hover:scale-125 transition-transform duration-1000"
      >
      </div>
      <div
        class="absolute -bottom-10 -left-10 w-40 h-40 bg-brand-purple/30 blur-3xl rounded-full group-hover:scale-125 transition-transform duration-1000"
      >
      </div>

      <!-- Subtle inner border for premium feel -->
      <div
        class="absolute inset-0 border border-white/5 rounded-[40px] lg:rounded-[56px] pointer-events-none"
      >
      </div>
    </div>
  </div>
</section>
