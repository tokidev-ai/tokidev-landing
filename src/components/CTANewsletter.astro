<div class="w-full max-w-[1120px] rounded-[24px] md:rounded-[28px] border border-white/8 p-6 sm:p-10 md:p-[64px] overflow-hidden flex flex-col items-center justify-center gap-6 relative" style="background-image: linear-gradient(18.0967deg, rgba(218, 41, 132, 0.14) 14.639%, rgba(164, 6, 233, 0.08) 50%, rgb(10, 17, 26) 85.361%);">
  
  <!-- Violet Orb top-left -->
  <div class="absolute -top-[50px] -left-[50px] w-[350px] h-[350px] md:w-[500px] md:h-[500px] bg-[#A406E9]/20 rounded-full blur-[100px] pointer-events-none"></div>

  <!-- Content -->
  <div class="flex flex-col items-center text-center relative z-10">
    <span class="font-semibold text-[#DA2984] text-[12px] tracking-[3px] uppercase mb-4">
      Join the newsletter
    </span>
    
    <h2 class="font-bold text-white text-[32px] md:text-[38px] leading-[1.2] md:leading-[46px] mb-4 max-w-[600px]">
      New essays, straight to your inbox
    </h2>
    
    <p class="font-normal text-[#c6cad0] text-[15px] leading-[24px] max-w-[560px] mb-8">
      One email every other week — motion studies, build notes, and the occasional side project. No filler, unsubscribe anytime.
    </p>

    <!-- Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 w-full">
      <button class="w-full sm:w-auto px-7 py-3.5 rounded-full bg-gradient-to-r from-[#DA2984] to-[#A406E9] text-white font-semibold text-[14px] shadow-[0_0_24px_rgba(218,41,132,0.35)] hover:shadow-[0_0_35px_rgba(218,41,132,0.5)] transition-all hover:-translate-y-0.5 cursor-pointer">
        Subscribe
      </button>
      <a href="/blog" class="w-full sm:w-auto px-7 py-3.5 rounded-full border border-white/15 text-white font-semibold text-[14px] hover:bg-white/5 transition-colors text-center cursor-pointer">
        Read more essays
      </a>
    </div>
  </div>

</div>
