---
/**
 * FreeResources.astro
 * Componente de la sección 08 — Recursos Gratis.
 * Consume los datos desde src/data/resources.ts y renderiza píldoras animadas con levitación flotante en CSS.
 */
import { ArrowRight, Sparkles } from 'lucide-astro';
import { freeResources } from '../data/resources';
---

<section id="resources" class="py-16 lg:py-24 w-full flex flex-col items-center">
  <div class="w-full flex flex-col lg:flex-row items-center justify-between gap-12 z-10">
    
    <!-- Columna Izquierda: Información y CTA -->
    <div class="flex flex-col items-start gap-6 w-full lg:max-w-[460px]">
      <p class="font-mono font-medium text-xs tracking-[0.24px] text-[#DA2984] uppercase">
        08 — RECURSOS GRATIS
      </p>

      <h2 class="font-bold text-4xl sm:text-5xl lg:text-[56px] text-white tracking-tight leading-none">
        Aprende gratis.
      </h2>

      <p class="text-[#a0a0b4] text-base sm:text-[17px] leading-relaxed">
        Guías, plantillas y notas que uso a diario. Todo en el hub de Tokidev.
      </p>

      <div class="flex flex-col items-start gap-2 pt-2 shrink-0">
        <a 
          href="https://recursos.tokidev.com" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 px-7 py-4 rounded-[12px] bg-gradient-to-r from-[#DA2984] to-[#A406E9] text-white text-[15px] font-semibold hover:brightness-110 shadow-lg shadow-purple-900/30 transition-all cursor-pointer active:scale-95 select-none group"
        >
          <span>Ir al hub de recursos</span>
          <ArrowRight size={18} class="font-bold transition-transform group-hover:translate-x-1 duration-300" />
        </a>
        <span class="font-mono font-medium text-[11px] text-[#a0a0b4] tracking-[0.22px] uppercase pl-1">
          SITIO EXTERNO ↗
        </span>
      </div>
    </div>

    <!-- Columna Derecha: Píldoras Flotantes e Interactivas -->
    <div class="w-full lg:w-[560px] h-[360px] relative shrink-0 flex items-center justify-center overflow-visible">
      
      <!-- Esfera Luminosa Atmosférica de Fondo -->
      <div class="absolute w-[320px] sm:w-[360px] h-[320px] sm:h-[360px] bg-gradient-to-tr from-[#A406E9]/25 via-[#DA2984]/20 to-transparent blur-3xl rounded-full pointer-events-none"></div>

      <!-- Píldoras Secundarias y Destacada desde la fuente de datos -->
      {freeResources.map((res) => (
        res.isFeatured ? (
          <div 
            class={`absolute ${res.top} ${res.left} animate-floating bg-gradient-to-r from-[#DA2984] to-[#A406E9] px-5 py-3 rounded-full flex items-center gap-2.5 shadow-xl shadow-purple-900/40 hover:scale-105 transition-all duration-300 cursor-pointer`}
            style={`animation-delay: ${res.delay};`}
          >
            <Sparkles size={16} class="text-white animate-pulse" />
            <span class="font-semibold text-sm text-white whitespace-nowrap">
              {res.label}
            </span>
          </div>
        ) : (
          <div 
            class={`absolute ${res.top} ${res.left} ${res.rotate} animate-floating backdrop-blur-md bg-white/5 border border-white/10 px-4 py-3 rounded-full flex items-center gap-2.5 shadow-xl shadow-purple-950/20 hover:scale-105 hover:rotate-0 hover:bg-white/10 hover:border-white/20 transition-all duration-300 cursor-pointer group`}
            style={`animation-delay: ${res.delay};`}
          >
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#DA2984] opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-[#DA2984]"></span>
            </span>
            <span class="font-semibold text-sm text-white group-hover:text-white transition-colors whitespace-nowrap">
              {res.label}
            </span>
          </div>
        )
      ))}

    </div>

  </div>
</section>

<style>
  @keyframes floating {
    0%, 100% {
      transform: translateY(0px) rotate(var(--tw-rotate, 0deg));
    }
    50% {
      transform: translateY(-10px) rotate(var(--tw-rotate, 0deg));
    }
  }

  .animate-floating {
    animation: floating 4s ease-in-out infinite;
  }
</style>
