---
/**
 * FeaturedBlogPost.astro
 * Componente que renderiza el post destacado del blog.
 * Alineado al nodo 104:1410 de Figma.
 */

interface Props {
  title: string;
  excerpt: string;
  date: string;
  author: string;
  readTime: string;
  category: string;
  url: string;
}

const { title, excerpt, date, author, readTime, category, url } = Astro.props;
---

<div class="flex flex-col gap-4 w-[92%] max-w-[1120px] mx-auto mt-6 pb-12 relative">
  <!-- Eyebrow (Figma Node 104:1411) -->
  <p class="font-mono font-medium text-xs tracking-[0.36px] text-[#DA2984] uppercase">
    FEATURED POST ★
  </p>

  <!-- Featured Card (Figma Node 104:1412) -->
  <a 
    href={url} 
    class="group h-[440px] rounded-[20px] overflow-hidden relative p-7 sm:p-9 flex flex-col justify-end transition-all duration-500 hover:scale-[1.01] shadow-2xl shadow-purple-950/30 cursor-pointer"
    style="background: linear-gradient(158.552deg, rgb(115, 26, 199) 14.085%, rgb(242, 107, 56) 84.507%)"
  >
    <!-- Foto indicativo arriba a la derecha (Figma Node 104:1413) -->
    <span class="absolute top-4 right-6 font-mono text-[10px] text-white/50 tracking-[0.2px]">
      FOTO ▦
    </span>

    <!-- Gradiente Oscuro de fondo para legibilidad (Figma Node 104:1414) -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-[#050510]/95 z-0"></div>

    <!-- Contenido del Artículo (Figma Node 104:1415) -->
    <div class="relative z-10 flex flex-col items-start gap-3 w-full">
      <div class="bg-black/30 border border-white/20 px-3 py-1.5 rounded-full backdrop-blur-md">
        <span class="font-mono font-semibold text-[10.5px] text-white tracking-[0.315px] uppercase">
          {category}
        </span>
      </div>

      <h2 class="font-bold text-2xl sm:text-3xl lg:text-[36px] text-white leading-snug tracking-tight max-w-[720px] group-hover:text-white/90 transition-colors">
        {title}
      </h2>

      <div class="w-full flex items-center justify-between pt-2 text-xs font-mono text-white/70">
        <span class="font-mono text-[11px] tracking-[0.11px] uppercase">
          {date} · {readTime}
        </span>
        <div class="flex items-center gap-1.5 text-sm font-sans font-semibold text-white group-hover:translate-x-1 transition-transform duration-300">
          <span>Read</span>
          <span>→</span>
        </div>
      </div>
    </div>
  </a>
</div>
