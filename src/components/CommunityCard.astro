---
// ─── Componente CommunityCard ───
// Tarjeta individual de comunidad / reconocimientos.
// Implementación fidelizada al nodo 66:1041 de Figma.
import type { HTMLAttributes } from 'astro/types';

interface Props {
  title: string;
  description: string;
  icon: any;
}

const { title, description, icon: Icon } = Astro.props;
---

<div class="bg-white/[0.03] border border-white/[0.08] rounded-[18px] p-6 flex flex-col gap-3.5 items-start transition-all duration-300 hover:border-white/20 hover:bg-white/[0.05] group shadow-lg shadow-purple-950/10 min-h-[200px]">
  <!-- Ícono en contenedor de gradiente magenta-púrpura -->
  <div class="w-10 h-10 rounded-[10px] bg-gradient-to-r from-[#DA2984] to-[#A406E9] flex items-center justify-center shrink-0 shadow-md shadow-purple-900/30 group-hover:scale-105 transition-transform">
    <Icon size={18} class="text-white" />
  </div>

  <!-- Contenido informativo -->
  <div class="flex flex-col gap-1.5 flex-1">
    <h3 class="font-semibold text-base sm:text-[16px] text-white tracking-tight group-hover:text-[#FA743F] transition-colors">
      {title}
    </h3>
    <p class="text-[#a0a0b4] text-xs sm:text-[12px] leading-[19px]">
      {description}
    </p>
  </div>
</div>
