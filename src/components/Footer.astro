---
import { Github, Linkedin, Twitter, Mail } from 'lucide-astro';

const socialLinks = [
  { icon: Linkedin, href: "#", label: "LinkedIn" },
  { icon: Github, href: "#", label: "GitHub" },
  { icon: Twitter, href: "#", label: "Twitter" },
  { icon: Mail, href: "#", label: "Email" }
];
---

<footer class="py-12 flex justify-center border-t border-brand-border/10">
  <div class="max-w-[1140px] w-full flex items-center justify-between px-4">
    
    <!-- Logo & Brand Info -->
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-orange to-brand-yellow/80 flex items-center justify-center">
        <span class="text-white font-bold text-lg leading-none pt-0.5">t</span>
      </div>
      <div class="flex flex-col">
        <span class="text-[16px] font-bold text-brand-text/90 leading-tight tracking-tight">Tokidev</span>
        <span class="text-[11px] font-medium text-brand-text/30 uppercase tracking-tighter">
          Senior Fullstack Engineer
        </span>
      </div>
    </div>

    <!-- Social Links -->
    <div class="flex gap-4">
      {socialLinks.map((social) => (
        <a href={social.href} aria-label={social.label} 
           class="w-9 h-9 flex items-center justify-center rounded-xl bg-[#2d2550]/40 border border-brand-border/12 text-brand-orange/70 hover:text-brand-orange hover:bg-[#2d2550]/60 transition-all border-solid">
          <social.icon size={16} />
        </a>
      ))}
    </div>
  </div>
</footer>
