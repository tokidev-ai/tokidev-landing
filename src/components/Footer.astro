---
/**
 * Footer.astro
 * Componente del Footer principal de la landing.
 * Implementación fidelizada al nodo 66:1143 de Figma.
 * Usa IsotivoTokidev.svg para el logotipo izquierdo y estiliza los botones de redes sociales a 54px para máxima consistencia visual con el Hero.
 */
import { Github, Linkedin, Instagram, Mail } from 'lucide-astro';

const socialLinks = [
  { 
    icon: Github, 
    href: "https://github.com/tokidev-ai", 
    label: "GitHub" 
  },
  { 
    icon: Linkedin, 
    href: "https://www.linkedin.com/in/tokidev/", 
    label: "LinkedIn" 
  },
  { 
    icon: Instagram, 
    href: "https://www.instagram.com/tokidev.ai/", 
    label: "Instagram" 
  },
  { 
    icon: Mail, 
    href: "mailto:rodrigo.torricodelcastillo@gmail.com", 
    label: "Email" 
  }
];
---

<footer 
  class="w-full flex justify-center border-t border-white/10 mt-16"
>
  <div class="w-[92%] max-w-[1120px] py-12 flex flex-col md:flex-row items-center justify-between gap-6 md:gap-4">
    <!-- Logotipo e Información Izquierda (Figma 66:1144) -->
    <div class="flex items-center gap-3 shrink-0">
      <div class="h-9 w-auto flex items-center justify-center shrink-0">
        <img 
          src="/assets/logos/IsotivoTokidev.svg" 
          alt="Tokidev Isotipo" 
          class="h-9 w-auto object-contain"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <!-- Fallback en caso de que falle la carga -->
        <div class="hidden w-8 h-8 rounded-lg bg-gradient-to-r from-brand-red to-brand-orange items-center justify-center shadow-sm">
          <span class="text-white font-bold text-lg leading-none">T</span>
        </div>
      </div>
      <div class="flex flex-col items-start leading-none gap-1">
        <p class="font-bold text-base text-white tracking-tight">
          Tokidev
        </p>
        <p class="text-[#a0a0b4] text-xs font-medium">
          Senior Fullstack Engineer
        </p>
      </div>
    </div>

    <!-- Botones de Redes Sociales Derecha (Figma 66:1153 - Botones reducidos a 44px para mayor finura visual) -->
    <div class="flex gap-3.5 items-center shrink-0">
      {socialLinks.map((social) => (
        <a
          href={social.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={social.label}
          class="backdrop-blur-[5px] bg-white/5 border border-white/10 flex items-center justify-center rounded-xl w-11 h-11 hover:bg-white/10 hover:border-white/20 hover:scale-105 transition-all duration-300 shadow-md shadow-purple-950/20"
        >
          <social.icon size={18} class="text-white" />
        </a>
      ))}
    </div>
  </div>
</footer>
