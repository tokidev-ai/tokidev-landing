---
import { Github, Linkedin, Instagram, Mail } from "lucide-astro";

const socialLinks = [
  {
    icon: Linkedin,
    href: "https://www.linkedin.com/in/tokidev/",
    label: "LinkedIn",
  },
  { icon: Github, href: "https://github.com/tokidev-ai", label: "GitHub" },
  { icon: Instagram, href: "https://www.instagram.com/tokidev.ai/", label: "Instagram" },
  { icon: Mail, href: "mailto:rodrigo.torricodelcastillo@gmail.com", label: "Email" },
];
---

<footer class="py-12 md:py-16 flex justify-center border-t border-brand-border/10">
  <div class="w-[92%] max-w-[1120px] flex flex-col md:flex-row items-center justify-between gap-8 md:gap-4">
    <!-- Logo & Brand Info -->
    <div class="flex items-center gap-3">
      <div
        class="w-8 h-8 rounded-lg bg-linear-to-br from-brand-orange to-brand-yellow/80 flex items-center justify-center"
      >
        <span class="text-white font-bold text-lg leading-none pt-0.5">t</span>
      </div>
      <div class="flex flex-col">
        <span
          class="text-[16px] font-bold text-brand-text/90 leading-tight tracking-tight"
          >Tokidev</span
        >
        <span
          class="text-[11px] font-medium text-brand-text/30 uppercase tracking-tighter"
        >
          Senior Fullstack Engineer
        </span>
      </div>
    </div>

    <!-- Navigation (Mobile focused) -->
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 md:hidden">
      {['About', 'Experience', 'Projects', 'Community', 'Blog'].map(link => (
        <a href={link === 'Blog' ? '/blog' : `/#${link.toLowerCase()}`} class="text-[13px] font-medium text-brand-text/40 hover:text-brand-orange transition-colors">
          {link}
        </a>
      ))}
    </div>

    <!-- Social Links -->
    <div class="flex gap-4">
      {
        socialLinks.map((social) => (
          <a
            href={social.href}
            aria-label={social.label}
            class="w-10 h-10 md:w-9 md:h-9 flex items-center justify-center rounded-xl bg-[#2d2550]/40 border border-brand-border/12 text-brand-orange/70 hover:text-brand-orange hover:bg-[#2d2550]/60 transition-all border-solid"
          >
            <social.icon size={18} />
          </a>
        ))
      }
    </div>

    <!-- Copyright (Mobile relative position) -->
    <div class="md:hidden text-[11px] text-brand-text/20 font-medium">
      © {new Date().getFullYear()} Tokidev. All rights reserved.
    </div>
  </div>
</footer>
