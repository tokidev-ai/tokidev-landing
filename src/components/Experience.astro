---
/**
 * Experience.astro
 * Componente de la sección 04 — Carrera Profesional (Timeline).
 * Desacopla la fuente de datos importando experiencesList desde src/data/experience.ts.
 */
import ExperienceCard from "./ExperienceCard.astro";
import { experiencesList } from "../data/experience";
---

<section id="experience" class="py-16 lg:py-24 w-full flex flex-col items-center">
  <!-- Cabecera de la Sección según Figma (nodo 66:991) -->
  <div class="w-full flex flex-col gap-2.5 items-start mb-12">
    <p class="font-mono font-medium text-xs tracking-[0.6px] bg-clip-text text-transparent bg-gradient-to-r from-[#DA2984] to-[#A406E9] uppercase">
      04 — EXPERIENCE
    </p>
    <h2 class="font-bold text-3xl sm:text-4xl lg:text-[40px] text-white tracking-tight">
      Where I’ve shipped.
    </h2>
  </div>

  <!-- Línea de Tiempo / Timeline (nodo 66:994) -->
  <div class="w-full flex flex-col items-start relative">
    {experiencesList.map((exp, idx) => (
      <ExperienceCard 
        company={exp.company}
        role={exp.role}
        period={exp.period}
        description={exp.description}
        isCurrent={exp.isCurrent}
        logoInitial={exp.logoInitial}
        logoColor={exp.logoColor}
        logoUrl={exp.logoUrl}
        isLast={idx === experiencesList.length - 1} 
      />
    ))}
  </div>
</section>
