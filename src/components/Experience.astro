---
import ExperienceCard from "./ExperienceCard.astro";

const experiences = [
  {
    company: "Unosquare",
    role: "Senior Software Engineer",
    period: "2021 — Present",
    description:
      "Leading enterprise transformation through scalable cloud architectures.",
    color: "#ef6c4a",
    isCurrent: true,
  },
  {
    company: "NICE CXone",
    role: "Fullstack Engineer",
    period: "2019 — 2021",
    description:
      "Building real-time communication platforms for global enterprise.",
    color: "#f5a623",
  },
  {
    company: "Special Tours",
    role: "Software Developer",
    period: "2017 — 2019",
    description:
      "Engineering complex booking engines for the European travel market.",
    color: "#7b5ea7",
  },
];
---

<section id="experience" class="py-12 md:py-20 flex justify-center">
  <div class="w-full flex flex-col items-center">
    <!-- Section Header -->
    <div class="w-full flex flex-col items-start lg:items-end mb-12 md:mb-16">
      <div class="flex items-center gap-2 mb-2">
        <div class="h-px w-10 bg-linear-to-r from-brand-orange to-transparent">
        </div>
        <span
          class="font-mono font-medium text-[#ff8a5c] text-sm tracking-[2.88px] uppercase"
        >
          EXPERIENCE
        </span>
      </div>
      <h2
        class="text-[32px] md:text-[38px] font-bold tracking-[-0.76px] text-white/80"
      >
        Where I've shipped.
      </h2>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
      {experiences.map((exp) => <ExperienceCard {...exp} />)}
    </div>
  </div>
</section>
