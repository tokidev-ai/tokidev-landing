---

<div class="w-full max-w-[720px] backdrop-blur-[10px] bg-linear-to-r from-white/4 to-white/1 border border-white/8 rounded-[24px] px-6 py-6 md:px-[32px] md:py-[28px] overflow-hidden flex flex-col md:flex-row items-start md:items-center gap-6">
  
  <!-- Avatar Placeholder (Gradient abstract to match the Figma's vibe) -->
  <div class="w-[80px] h-[80px] shrink-0 rounded-full bg-linear-to-br from-brand-purple/40 to-brand-orange/40 p-1">
    <div class="w-full h-full rounded-full bg-brand-bg flex items-center justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-brand-orange/30 blur-[10px]"></div>
        <div class="absolute top-[20%] left-[20%] w-[40px] h-[40px] bg-brand-purple/40 rounded-full blur-sm"></div>
    </div>
  </div>

  <!-- Info -->
  <div class="flex flex-col items-start gap-1.5 flex-1 min-w-0">
    <span class="font-semibold text-brand-orange text-[10px] tracking-[2px] uppercase">
      Written By
    </span>
    
    <h3 class="font-bold text-white text-[22px]">
      Sofia Navarro
    </h3>
    
    <p class="font-normal text-brand-text/80 text-[14px] leading-[1.55] mt-1 max-w-[500px]">
      Design engineer blending motion, systems thinking, and a little bit of magic. Currently crafting interfaces at Tokidev Studio.
    </p>

    <!-- Socials -->
    <div class="flex flex-wrap items-center gap-2 mt-3">
      <a href="#" class="px-3.5 py-2 rounded-full border border-white/10 hover:border-white/20 hover:bg-white/5 transition-colors flex items-center justify-center">
        <span class="font-medium text-[12px] text-white">Follow on X</span>
      </a>
      <a href="#" class="px-3.5 py-2 rounded-full border border-white/10 hover:border-white/20 hover:bg-white/5 transition-colors flex items-center justify-center">
        <span class="font-medium text-[12px] text-white">Personal site</span>
      </a>
    </div>
  </div>

</div>
