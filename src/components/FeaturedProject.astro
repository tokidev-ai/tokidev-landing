---
/**
 * FeaturedProject.astro
 * Componente de la sección 02 — Selected Work.
 * Importa los datos del proyecto destacado de forma limpia desde src/data/projects.ts.
 */
import ProjectCard from "./ProjectCard.astro";
import { featuredProject } from "../data/projects";
---

<section
  id="projects"
  class="w-full flex justify-center relative py-16 lg:py-24"
>
  <div class="w-full relative flex flex-col items-start gap-8">
    <!-- Cabecera de Sección según Figma (nodo 66:886) -->
    <div class="flex flex-col gap-2.5 items-start">
      <p class="font-mono font-medium text-xs tracking-[0.6px] bg-clip-text text-transparent bg-gradient-to-r from-[#DA2984] to-[#A406E9] uppercase">
        02 — SELECTED WORK
      </p>
      <h2 class="font-bold text-3xl sm:text-4xl text-white tracking-tight">
        Things I’ve built.
      </h2>
    </div>

    <!-- Contenedor de Tarjeta de Proyecto -->
    <div class="w-full">
      <ProjectCard {...featuredProject} />
    </div>
  </div>
</section>
