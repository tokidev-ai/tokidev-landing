---
import { ArrowRight } from "lucide-astro";
---

<section class="w-full flex justify-center pb-24 lg:pb-32">
  <div class="w-[92%] max-w-[1120px]">
    <div class="relative w-full rounded-[32px] border border-white/8 flex flex-col items-center justify-center overflow-hidden bg-linear-to-b from-[#1a1029]/65 to-[#0d0d23]/85 p-12 lg:p-[60px] text-center">
      
      <!-- Abstract Glow Overlays -->
      <div class="absolute right-[-10%] sm:right-[15%] lg:right-[10%] top-[-10%] sm:top-[20%] w-[520px] h-[520px] bg-brand-orange/15 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute left-[-20%] sm:left-[-10%] top-[-20%] w-[440px] h-[440px] bg-brand-yellow/10 rounded-full blur-[90px] pointer-events-none"></div>

      <div class="relative z-10 flex flex-col items-center gap-[12px]">
        <h2 class="text-[32px] md:text-[40px] font-bold text-white tracking-[-0.8px] leading-[1.1]">
          Ready to build something great?
        </h2>
        <p class="text-brand-text/80 text-[16px] font-normal">
          Let's talk about your next project.
        </p>

        <div class="mt-4">
          <a href="/#contact" class="flex items-center justify-center gap-2 px-7 py-4 rounded-full bg-linear-to-r from-brand-orange to-[#f4845c] shadow-[0_12px_48px_rgba(239,108,74,0.35)] hover:shadow-[0_12px_60px_rgba(239,108,74,0.5)] transition-all hover:-translate-y-0.5">
            <span class="text-[15px] font-semibold text-white">Let's talk</span>
            <ArrowRight size={18} class="text-white" />
          </a>
        </div>
      </div>
      
    </div>
  </div>
</section>
