---
import { Box, Code2, Database } from 'lucide-astro';

interface Props {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  tech: string[];
  color: string;
}

const { id, title, subtitle, description, tech, color } = Astro.props;
---

<div class="relative w-[1180px] h-[580px] rounded-[24px] border border-brand-border/10 overflow-hidden group">
  <!-- Secondary Glass Background Layer (from Figma 6:935) -->
  <div class="absolute inset-x-[-1px] inset-y-[-1px] bg-gradient-to-br from-black/36 to-zinc-400/5 backdrop-blur-[15px] rounded-[32px] -z-10"></div>
  
  <!-- Primary Background -->
  <div class="absolute inset-0 bg-brand-glass/60 backdrop-blur-[10px] -z-20"></div>
  
  <!-- Content Container: left: 89px, top: 123px -->
  <div class="absolute left-[89px] top-[123px] w-[600px] flex flex-col items-start z-10">
    <p class="font-bold text-[14px] text-brand-text/30 whitespace-nowrap mb-[12px]">
      {id}
    </p>
    
    <div class="bg-brand-purple/15 border border-brand-purple/20 px-[14px] py-[6px] rounded-full mb-[20px]">
      <p class="text-brand-purple text-[11px] font-bold tracking-[0.44px] uppercase whitespace-nowrap">
        Selected Projects
      </p>
    </div>

    <h3 class="text-[40px] font-bold tracking-[-0.8px] text-brand-text/95 leading-[48px] mb-[20px]">
      <span style={`color: ${color};`}>{title}</span>: {subtitle}
    </h3>

    <div class="text-brand-text/40 text-[14px] font-medium leading-[24px] mb-[24px] max-w-[480px]">
      <p>{description}</p>
    </div>

    <div class="flex gap-[8px] items-start">
      {tech.map((t) => (
        <div class="bg-brand-orange/10 border border-brand-orange/15 px-[14px] py-[6px] rounded-[6px]">
          <span class="text-[11px] font-bold text-brand-orange/80 tracking-[0.44px] uppercase whitespace-nowrap">
            {t}
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- Visual Mockup Area -->
  <div class="absolute left-[659px] top-[49px] w-[480px] h-[480px] relative">
      <!-- Glow behind mockup (imgCardGlow) -->
      <div class="absolute inset-0 bg-brand-orange/30 blur-[100px] rounded-full opacity-60 group-hover:opacity-100 transition-opacity duration-700"></div>
      
      <!-- Mockup Card (imgProjectImageCard) -->
      <div class="absolute left-[30px] top-[30px] w-[420px] h-[420px] bg-gradient-to-br from-[#1a1029] to-black/20 border border-white/10 rounded-2xl shadow-2xl relative overflow-hidden group-hover:scale-[1.03] transition-transform duration-700">
          <div class="absolute inset-0 p-8 flex flex-col gap-4">
              <div class="flex items-center gap-3">
                  <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                  <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
              </div>
              <div class="w-full h-px bg-white/5"></div>
              <div class="flex flex-col gap-2 opacity-40">
                  <div class="w-[80%] h-3 bg-white/10 rounded"></div>
                  <div class="w-[60%] h-3 bg-white/10 rounded"></div>
                  <div class="w-[90%] h-3 bg-white/10 rounded"></div>
              </div>
              <div class="mt-auto flex justify-center pb-4">
                   <Code2 size={48} class="text-brand-purple/50 animate-pulse" />
              </div>
          </div>
      </div>
  </div>
</div>
