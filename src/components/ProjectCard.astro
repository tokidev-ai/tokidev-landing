---
// ─── Componente ProjectCard ───
// Implementación fidelizada al nodo 66:889 de Figma.
// Incluye enlace directo a la app en vivo en nueva pestaña (target="_blank").
interface Props {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  tech: string[];
  color?: string;
  link?: string;
}

const { id, title, subtitle, description, tech, link = "https://solveos-app.netlify.app/" } = Astro.props;
---

<div
  class="relative w-full bg-white/[0.03] border border-white/[0.09] rounded-[24px] lg:rounded-[32px] overflow-hidden flex flex-col lg:flex-row items-stretch transition-all duration-300 hover:border-white/20 group shadow-2xl shadow-purple-950/20"
>
  <!-- Columna Izquierda: Información de Proyecto (Figma 66:890) -->
  <div class="flex-1 p-8 lg:p-11 flex flex-col justify-between items-start gap-6 z-10">
    
    <!-- Fila de Índice y Badge FEATURED -->
    <div class="flex items-center gap-3.5">
      <span class="font-mono font-bold text-4xl lg:text-5xl tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-[#FA743F] to-[#DA2984]">
        {id}
      </span>
      <div class="px-3 py-1.5 rounded-full bg-gradient-to-r from-[#DA2984] to-[#A406E9] flex items-center justify-center shadow-md shadow-purple-900/30">
        <span class="font-mono font-medium text-[10px] text-white tracking-[0.3px] uppercase">
          FEATURED
        </span>
      </div>
    </div>

    <!-- Título y Subtítulo -->
    <h3 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white tracking-tight leading-snug">
      {title} <span class="font-normal text-white/90">— {subtitle}</span>
    </h3>

    <!-- Descripción Explicativa -->
    <p class="text-[#a0a0b4] text-sm sm:text-base leading-relaxed max-w-[540px]">
      {description}
    </p>

    <!-- Chips de Tecnologías (Figma 66:897) -->
    <div class="flex flex-wrap gap-2.5 items-center">
      {tech.map((t) => (
        <div class="bg-white/5 border border-[#DA2984] px-3.5 py-1.5 rounded-full backdrop-blur-sm">
          <span class="font-mono font-medium text-[11px] text-[#d7d7e6] tracking-[0.22px] uppercase">
            {t}
          </span>
        </div>
      ))}
    </div>

    <!-- Enlace View project (Redirige a Netlify en nueva pestaña) -->
    <div class="pt-2">
      <a 
        href={link} 
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-semibold text-sm sm:text-base bg-clip-text text-transparent bg-gradient-to-r from-[#FA743F] to-[#DA2984] hover:brightness-125 transition-all cursor-pointer group/link"
      >
        <span>View project</span>
        <span class="text-[#DA2984] transition-transform group-hover/link:translate-x-1 duration-300">→</span>
      </a>
    </div>
  </div>

  <!-- Columna Derecha: Mockup Visual e Iluminación (Figma 66:905) -->
  <div 
    class="lg:w-[480px] shrink-0 relative min-h-[260px] lg:min-h-[380px] flex items-center justify-center overflow-hidden"
    style="background: linear-gradient(237.5deg, rgb(18, 14, 32) 13.397%, rgb(10, 8, 20) 86.603%)"
  >
    <!-- Brillo decorativo de fondo -->
    <div class="absolute w-72 h-72 bg-[#A406E9]/20 blur-3xl rounded-full -top-10 -right-10 group-hover:scale-125 transition-transform duration-1000"></div>
    <div class="absolute w-72 h-72 bg-[#DA2984]/20 blur-3xl rounded-full -bottom-10 -left-10 group-hover:scale-125 transition-transform duration-1000"></div>

    <!-- Barra de acento horizontal superior -->
    <div class="absolute top-[30px] left-1/2 -translate-x-1/2 w-[80%] h-[3px] rounded-full bg-gradient-to-r from-[#DA2984] to-[#FA743F]"></div>

    <!-- Ecualizador gráfico decorativo -->
    <div class="flex items-end justify-center gap-3 h-[180px] z-10">
      {[
        { h: '60px', delay: '0ms' },
        { h: '110px', delay: '100ms' },
        { h: '80px', delay: '200ms' },
        { h: '150px', delay: '300ms' },
        { h: '100px', delay: '150ms' },
        { h: '170px', delay: '250ms' },
        { h: '130px', delay: '350ms' },
        { h: '90px', delay: '400ms' },
      ].map((bar) => (
        <div 
          class="w-7 rounded-lg bg-gradient-to-b from-[#A406E9] to-[#DA2984] shadow-md shadow-purple-900/40 transition-all duration-500 group-hover:brightness-125"
          style={`height: ${bar.h}; transition-delay: ${bar.delay}`}
        ></div>
      ))}
    </div>
  </div>
</div>
