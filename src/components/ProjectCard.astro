---
import { Box, Code2, Database } from 'lucide-astro';

interface Props {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  tech: string[];
  color: string;
}

const { id, title, subtitle, description, tech, color } = Astro.props;
---

<div class="relative w-full max-w-[1180px] h-[580px] rounded-[24px] border border-brand-border/10 overflow-hidden group">
  <!-- Glass Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-black/35 to-white/5 backdrop-blur-xl -z-10"></div>
  
  <!-- Content Container -->
  <div class="absolute left-[89px] top-[123px] w-[600px] flex flex-col items-start z-10">
    <span class="text-brand-text/30 font-bold text-sm mb-3">01</span>
    
    <div class="px-3.5 py-1.5 bg-brand-purple/15 border border-brand-purple/20 rounded-full mb-5">
      <span class="text-brand-purple text-[11px] font-bold tracking-[0.44px] uppercase">
        Selected Projects
      </span>
    </div>

    <h3 class="text-[40px] font-bold tracking-[-0.8px] text-brand-text/95 leading-tight mb-5">
      <span style={`color: ${color};`}>{title}</span>: {subtitle}
    </h3>

    <div class="text-brand-text/40 text-sm leading-[1.7] mb-6 max-w-[480px]">
      <p>{description}</p>
    </div>

    <div class="flex gap-2">
      {tech.map((t) => (
        <div class="px-3.5 py-1.5 bg-brand-orange/10 border border-brand-orange/15 rounded-md">
          <span class="text-[11px] font-bold text-brand-orange/80 tracking-[0.44px] uppercase">
            {t}
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- Visual Mockup Area -->
  <div class="absolute right-[120px] top-[140px] w-[420px] h-[300px] rounded-2xl bg-gradient-to-br from-[#1a1029] to-black/20 border border-white/5 shadow-2xl relative overflow-hidden group-hover:scale-105 transition-transform duration-700">
    <div class="absolute inset-0 p-8 flex flex-col gap-4">
        <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
        </div>
        <div class="w-full h-px bg-white/5"></div>
        <div class="flex flex-col gap-2 opacity-40">
            <div class="w-[80%] h-3 bg-white/10 rounded"></div>
            <div class="w-[60%] h-3 bg-white/10 rounded"></div>
            <div class="w-[90%] h-3 bg-white/10 rounded"></div>
        </div>
        <div class="mt-auto flex justify-center pb-4">
             <Code2 size={48} class="text-brand-purple/50 animate-pulse" />
        </div>
    </div>
    <!-- Glow behind mockup -->
    <div class="absolute -bottom-10 -right-10 w-48 h-48 bg-brand-purple/30 blur-3xl opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>
  </div>
</div>
