---
/**
 * BlogCard.astro
 * Componente que renderiza una tarjeta en el grid del blog.
 * Alineado al nodo 104:1427 de Figma.
 */

interface Props {
  title: string;
  excerpt: string;
  date: string;
  readTime: string;
  category: string;
  url: string;
  color?: string;
}

const { title, excerpt, date, readTime, category, url } = Astro.props;

// Mapeo dinámico de categorías a combinaciones de gradientes oficiales de Figma
const getCategoryGradient = (cat: string) => {
  const norm = cat.toLowerCase().trim();
  if (norm.includes('engineering')) {
    return 'linear-gradient(139.958deg, rgb(46, 41, 140) 14.085%, rgb(158, 26, 133) 84.507%)';
  }
  if (norm.includes('career')) {
    return 'linear-gradient(139.958deg, rgb(199, 33, 102) 14.085%, rgb(250, 128, 56) 84.507%)';
  }
  if (norm.includes('distributed')) {
    return 'linear-gradient(139.958deg, rgb(77, 33, 153) 14.085%, rgb(204, 41, 115) 84.507%)';
  }
  if (norm.includes('open source') || norm.includes('source')) {
    return 'linear-gradient(139.958deg, rgb(33, 77, 140) 14.085%, rgb(140, 31, 158) 84.507%)';
  }
  if (norm.includes('thoughts')) {
    return 'linear-gradient(139.958deg, rgb(140, 31, 128) 14.085%, rgb(242, 115, 64) 84.507%)';
  }
  // Default (por si acaso)
  return 'linear-gradient(139.958deg, rgb(115, 26, 199) 14.085%, rgb(242, 107, 56) 84.507%)';
};

const gradient = getCategoryGradient(category);
---

<a 
  href={url} 
  data-category={category} 
  class="group w-full max-w-[357px] mx-auto h-[300px] rounded-[20px] overflow-hidden relative p-7 flex flex-col justify-end transition-all duration-500 hover:scale-[1.015] shadow-xl hover:shadow-2xl shadow-purple-950/20 hover:shadow-purple-900/30 blog-card-element cursor-pointer"
  style={`background: ${gradient};`}
>
  <!-- Foto indicativo arriba a la derecha (Figma Node 104:1428) -->
  <span class="absolute top-4 right-6 font-mono text-[10px] text-white/50 tracking-[0.2px]">
    FOTO ▦
  </span>

  <!-- Gradiente Oscuro de fondo para legibilidad (Figma Node 104:1429) -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/10 to-[#050510]/95 z-0"></div>

  <!-- Contenido de la Tarjeta (Figma Node 104:1430) -->
  <div class="relative z-10 flex flex-col items-start gap-3 w-full">
    
    <!-- Categoría -->
    <div class="bg-black/30 border border-white/20 px-3 py-1 rounded-full backdrop-blur-md">
      <span class="font-mono font-semibold text-[10px] text-white tracking-[0.315px] uppercase">
        {category}
      </span>
    </div>

    <!-- Título -->
    <h3 class="font-bold text-[19px] sm:text-[20px] text-white leading-snug tracking-tight group-hover:text-white/95 transition-colors line-clamp-2">
      {title}
    </h3>

    <!-- Metadatos (Fecha · Lectura) -->
    <div class="w-full flex items-center justify-between pt-1 font-mono text-[11px] text-white/70 tracking-[0.11px]">
      <span>{date} · {readTime}</span>
      <div class="flex items-center gap-1 text-xs font-sans font-semibold text-white group-hover:translate-x-1 transition-transform duration-300">
        <span>Read</span>
        <span>→</span>
      </div>
    </div>

  </div>
</a>
