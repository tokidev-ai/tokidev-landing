---
// ─── Componente ExperienceCard ───
// Tarjeta de experiencia individual dentro de la línea de tiempo.
// Implementación fidelizada a los nodos 66:995, 66:1004, 66:1017 y 66:1030 de Figma.
interface Props {
  company: string;
  role: string;
  period: string;
  description: string;
  isCurrent?: boolean;
  isLast?: boolean;
  logoInitial?: string;
  logoColor?: string;
  logoUrl?: string;
}

const {
  company,
  role,
  period,
  description,
  isCurrent = false,
  isLast = false,
  logoInitial = "T",
  logoColor = "from-[#FA743F] to-[#DA2984]",
  logoUrl
} = Astro.props;
---

<div class="flex gap-4 sm:gap-7 items-start w-full relative group">
  <!-- Marcador de la Línea de Tiempo (Dot + Línea Vertical) -->
  <div class="flex flex-col items-center shrink-0 w-5 self-stretch">
    <div class="w-4 h-4 rounded-full bg-gradient-to-r from-[#DA2984] to-[#A406E9] shrink-0 mt-1.5 shadow-md shadow-purple-900/50 ring-4 ring-brand-bg"></div>
    {!isLast && (
      <div class="w-[2px] flex-1 bg-gradient-to-b from-[#DA2984]/60 to-[#A406E9]/60 my-1"></div>
    )}
  </div>

  <!-- Contenido de la Entrada (Período + Tarjeta de Rol) -->
  <div class="flex-1 flex flex-col gap-3.5 pb-10 min-w-0">
    
    <!-- Fila de Período y Badge CURRENT -->
    <div class="flex items-center gap-3">
      <span class="font-mono font-medium text-xs text-[#9696af] tracking-[0.48px] uppercase">
        {period}
      </span>
      {isCurrent && (
        <div class="px-2.5 py-0.5 rounded-full bg-gradient-to-r from-[#FA743F] to-[#DA2984] flex items-center justify-center shadow-sm">
          <span class="font-mono font-medium text-[9px] text-white tracking-[0.18px] uppercase">
            CURRENT
          </span>
        </div>
      )}
    </div>

    <!-- Tarjeta de Rol Glassmorphic (Figma 66:1004) -->
    <div class="bg-white/[0.03] border border-white/[0.08] rounded-[18px] p-6 sm:p-7 flex flex-col-reverse sm:flex-row items-start sm:items-center justify-between gap-5 w-full transition-all duration-300 hover:border-white/20 group-hover:bg-white/[0.05] shadow-lg shadow-purple-950/10">
      
      <!-- Texto Informativo -->
      <div class="flex flex-col gap-1.5 flex-1 min-w-0">
        <h3 class="font-bold text-xl sm:text-[22px] text-white tracking-tight">
          {role}
        </h3>
        <p class="font-semibold text-base bg-clip-text text-transparent bg-gradient-to-r from-[#FA743F] to-[#DA2984]">
          {company}
        </p>
        <p class="text-[#a0a0b4] text-sm leading-relaxed pt-0.5">
          {description}
        </p>
      </div>

      <!-- Logotipo / Avatar de la Empresa -->
      <div class={`w-14 h-14 sm:w-[68px] sm:h-[68px] rounded-full shrink-0 bg-gradient-to-br ${logoColor} flex items-center justify-center font-bold text-xl sm:text-2xl text-white shadow-md shadow-purple-900/30 overflow-hidden`}>
        {logoUrl ? (
          <img src={logoUrl} alt={`${company} logo`} class="w-full h-full object-cover" />
        ) : (
          <span>{logoInitial}</span>
        )}
      </div>

    </div>
  </div>
</div>
