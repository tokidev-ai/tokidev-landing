---
interface Props {
  company: string;
  role: string;
  period: string;
  description: string;
  color: string;
  isCurrent?: boolean;
  logo?: string;
}

const {
  company,
  role,
  period,
  description,
  color,
  isCurrent = false,
  logo,
} = Astro.props;
---

<div
  class={`relative flex flex-col items-center pt-10 md:pt-12 px-6 md:px-8 h-auto md:h-[470px] rounded-[24px] border border-solid overflow-hidden group transition-all duration-500 hover:scale-[1.02] pb-10 md:pb-0`}
  style={`border-color: ${color}1f;`}
>
  <!-- Glass Background -->
  <div
    class="absolute inset-0 bg-linear-to-br from-black/35 to-white/5 backdrop-blur-xl -z-10"
  >
  </div>

  <!-- Period and Badge -->
  <div class="flex items-center gap-2.5 mb-4 z-10">
    <span
      class="text-[10px] md:text-[11px] font-medium text-brand-text/30 tracking-[0.66px] uppercase"
    >
      {period}
    </span>
    {
      isCurrent && (
        <div class="px-2 py-1 bg-brand-orange/15 rounded-md border border-brand-orange/20">
          <span class="text-[9px] font-bold text-brand-orange tracking-[0.72px]">
            CURRENT
          </span>
        </div>
      )
    }
  </div>

  <!-- Role and Company -->
  <div class="text-center z-10 mb-4 px-2">
    <h3
      class="text-[28px] md:text-[32px] font-bold leading-[1.2] tracking-[-0.64px] text-white/95"
    >
      {role}
      <span style={`color: ${color};`}>{company}</span>
    </h3>
  </div>

  <!-- Description -->
  <p
    class="text-[14px] md:text-[13px] font-medium text-center text-brand-text/35 leading-normal max-w-[280px] z-10 mb-8 md:mb-0"
  >
    {description}
  </p>

  <div class="hidden md:block grow"></div>

  <!-- Glow Effect at bottom with Logo -->
  <div
    class="relative w-full h-[120px] md:h-[180px] opacity-60 group-hover:opacity-100 transition-opacity duration-700 mt-auto flex items-center justify-center"
  >
    <div
      class="absolute left-1/2 -translate-x-1/2 top-0 w-[300px] md:w-[400px] h-[300px] md:h-[400px] rounded-full blur-[80px] md:blur-[100px]"
      style={`background: ${color}33;`}
    >
    </div>
    <div
      class="absolute left-1/2 -translate-x-1/2 top-10 w-[150px] md:w-[200px] h-[150px] md:h-[200px] rounded-full blur-3xl"
      style={`background: ${color}66;`}
    >
    </div>

    <!-- Logo Container -->
    <div
      class="relative z-10 size-28 md:size-36 rounded-full bg-[#0f0a1a]/80 backdrop-blur-md border border-white/10 flex items-center justify-center overflow-hidden group-hover:border-white/20 transition-colors"
    >
      <img
        src={logo || "https://picsum.photos/200/200"}
        alt={company}
        class="w-full h-full object-cover"
      />
    </div>
  </div>
</div>
