---
// ─── Componente Capabilities & Impact ───
// Implementación fidelizada al nodo 66:832 de Figma (Sección Bento).
// Corrige el estado hover de las tarjetas (efecto gradiente oscuro + borde magenta al pasar el mouse) y mantiene el grid 2x2 de métricas en móvil.
import { Code2, Zap, Smartphone, Bot, TrendingUp } from 'lucide-astro';

const smallCapabilities = [
  {
    icon: Zap,
    title: "High Performance",
    desc: "Sub-100ms targets",
  },
  {
    icon: Smartphone,
    title: "Responsive Design",
    desc: "Mobile-first always",
  },
  {
    icon: Bot,
    title: "AI Automation",
    desc: "Cursor & n8n",
  },
  {
    icon: TrendingUp,
    title: "Always Learning",
    desc: "New stack monthly",
  }
];

const stats = [
  { value: "2+", label: "YEARS" },
  { value: "11+", label: "PROJECTS" },
  { value: "20+", label: "TECH" },
  { value: "∞", label: "COFFEE" }
];
---

<section id="capabilities" class="py-16 lg:py-24 w-full flex flex-col items-center">
  <!-- Cabecera de la Sección según Figma (nodo 66:833) -->
  <div class="w-full flex flex-col gap-2.5 items-start mb-10">
    <p class="font-mono font-medium text-xs tracking-[0.6px] bg-clip-text text-transparent bg-gradient-to-r from-[#DA2984] to-[#A406E9] uppercase">
      01 — WHAT I DO BEST
    </p>
    <h2 class="font-bold text-3xl sm:text-4xl text-white tracking-tight">
      Capabilities & impact.
    </h2>
  </div>

  <!-- Contenedor Principal en Grid / Bento -->
  <div class="w-full flex flex-col gap-5">
    <!-- FILA 1: Tarjeta Destacada (Clean Code) + Tile de Estadísticas 2x2 -->
    <div class="flex flex-col lg:flex-row gap-5 items-stretch w-full">
      
      <!-- Tarjeta Destacada Izquierda (Figma 66:838) -->
      <div class="flex-1 bg-white/[0.03] border border-white/[0.08] rounded-[20px] p-7 flex flex-col justify-between gap-6 relative overflow-hidden transition-all duration-300 hover:border-[#DA2984]/80 hover:bg-[linear-gradient(225deg,rgba(26,20,46,0.95)_13%,rgba(18,14,34,0.95)_86%)] hover:shadow-xl hover:shadow-purple-950/40 group">
        <!-- Ícono en contenedor de gradiente -->
        <div class="w-11 h-11 rounded-[12px] bg-gradient-to-r from-[#DA2984] to-[#A406E9] flex items-center justify-center shrink-0 shadow-md shadow-purple-900/30 group-hover:scale-105 transition-transform">
          <Code2 size={22} class="text-white" />
        </div>

        <div class="flex flex-col gap-2 z-10">
          <h3 class="font-semibold text-xl sm:text-2xl text-white tracking-tight group-hover:text-white transition-colors">
            Clean, scalable code
          </h3>
          <p class="text-[#a0a0b4] text-sm sm:text-base leading-relaxed max-w-[580px]">
            Best practices applied to architecture, naming, and testing — code that other engineers actually want to inherit.
          </p>
        </div>
      </div>

      <!-- Tile de Estadísticas Derecha 2x2 (Figma 66:845 - Con efecto Hover) -->
      <div 
        class="lg:w-[380px] shrink-0 bg-white/[0.03] border border-white/[0.08] rounded-[20px] p-7 flex flex-col justify-between gap-5 relative overflow-hidden transition-all duration-300 hover:border-[#DA2984]/80 hover:bg-[linear-gradient(225deg,rgba(26,20,46,0.95)_13%,rgba(18,14,34,0.95)_86%)] hover:shadow-xl hover:shadow-purple-950/40 group"
      >
        <p class="font-mono font-medium text-[11px] text-[#9696af] tracking-[0.44px] uppercase">
          BY THE NUMBERS
        </p>

        <!-- Grid 2x2 de Estadísticas estricto en móvil y desktop -->
        <div class="grid grid-cols-2 gap-x-4 gap-y-5">
          {stats.map((stat) => (
            <div class="flex flex-col gap-0.5">
              <p class="font-bold text-3xl sm:text-[34px] tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-[#FA743F] to-[#DA2984] group-hover:brightness-110 transition-all">
                {stat.value}
              </p>
              <p class="font-mono font-medium text-[10px] text-[#a0a0b4] tracking-[0.2px] uppercase">
                {stat.label}
              </p>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- FILA 2: Grid de 4 Capacidades en Fila (Figma 66:860) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 w-full">
      {smallCapabilities.map((cap) => (
        <div class="bg-white/[0.03] border border-white/[0.08] rounded-[20px] p-7 flex flex-col gap-4 items-start transition-all duration-300 hover:border-[#DA2984]/80 hover:bg-[linear-gradient(225deg,rgba(26,20,46,0.95)_13%,rgba(18,14,34,0.95)_86%)] hover:shadow-xl hover:shadow-purple-950/40 group">
          <div class="w-11 h-11 rounded-[12px] bg-gradient-to-r from-[#DA2984] to-[#A406E9] flex items-center justify-center shrink-0 shadow-md shadow-purple-900/30 group-hover:scale-105 transition-transform">
            <cap.icon size={20} class="text-white" />
          </div>
          <div class="flex flex-col gap-1">
            <h4 class="font-semibold text-base text-white group-hover:text-[#FA743F] transition-colors">
              {cap.title}
            </h4>
            <p class="text-[#a0a0b4] text-xs leading-snug">
              {cap.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
